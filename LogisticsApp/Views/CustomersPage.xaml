<UserControl x:Class="LogisticsApp.Views.CustomersPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:core="clr-namespace:LogisticsApp.Core"
             xmlns:local="clr-namespace:LogisticsApp.Views"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1100">

    <UserControl.Resources>
        <core:PermissionToVisibilityConverter x:Key="PermissionToVisibility"/>
        <local:CustomerTypeToTextConverter x:Key="CustomerTypeToTextConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:ContactWarningConverter x:Key="ContactWarningConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="20" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Column="0" Margin="0,0,25,0" VerticalAlignment="Center">
                    <Border Width="40" Height="40" Background="{StaticResource PrimaryLightBrush}" CornerRadius="8">
                        <iconPacks:PackIconMaterial Kind="StorefrontOutline" Foreground="{StaticResource PrimaryDarkBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" Width="20" Height="20"/>
                    </Border>
                    <StackPanel Margin="15,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Контрагенты" FontWeight="Bold" FontSize="16" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Справочник клиентов" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>

                <TextBox Grid.Column="1" Style="{StaticResource ModernTextBox}"
                         mah:TextBoxHelper.Watermark="Умный поиск (ИНН, Название, Адрес)..."
                         mah:TextBoxHelper.ClearTextButton="True"
                         Text="{Binding HighlightText, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,15,0" Height="40" VerticalContentAlignment="Center"/>

                <ComboBox Grid.Column="2"
                          mah:TextBoxHelper.Watermark="Вид контрагента"
                          SelectedIndex="{Binding SelectedTypeFilterIndex}"
                          Margin="0,0,15,0" Height="40" VerticalContentAlignment="Center"
                          Style="{StaticResource MahApps.Styles.ComboBox}">
                    <ComboBoxItem Content="Все виды"/>
                    <ComboBoxItem Content="Только Юр. лица"/>
                    <ComboBoxItem Content="Только ИП"/>
                    <ComboBoxItem Content="Только Физ. лица"/>
                </ComboBox>

                <Button Grid.Column="3" Command="{Binding RefreshCommand}" Style="{StaticResource MenuButton}" ToolTip="Обновить из БД" Height="40" Padding="15,0">
                    <iconPacks:PackIconMaterial Kind="Refresh" Width="16" Height="16" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                </Button>
            </Grid>
        </Border>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Customers}"
                  SelectedItem="{Binding SelectedCustomer}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  Margin="20"
                  EnableRowVirtualization="True"
                  EnableColumnVirtualization="True"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  ScrollViewer.CanContentScroll="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Вид" Binding="{Binding Type, Converter={StaticResource CustomerTypeToTextConverter}}" Width="100" Foreground="Gray"/>
                <DataGridTemplateColumn Header="ИНН" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock core:TextBlockHighlighter.Text="{Binding INN}"
                                       core:TextBlockHighlighter.Selection="{Binding DataContext.HighlightText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                       Foreground="#1976D2" FontWeight="SemiBold"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="КПП" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock core:TextBlockHighlighter.Text="{Binding KPP}"
                                       core:TextBlockHighlighter.Selection="{Binding DataContext.HighlightText, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Наименование" Width="240">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="AlertCircleOutline" 
                                                            Foreground="#F59E0B" 
                                                            Width="14" Height="14" 
                                                            Margin="0,0,8,0" 
                                                            VerticalAlignment="Center">
                                    <iconPacks:PackIconMaterial.Visibility>
                                        <MultiBinding Converter="{StaticResource ContactWarningConverter}">
                                            <Binding Path="Phone" />
                                            <Binding Path="Email" />
                                            <Binding Path="ContactPerson" />
                                        </MultiBinding>
                                    </iconPacks:PackIconMaterial.Visibility>
                                    <iconPacks:PackIconMaterial.ToolTip>
                                        <ToolTip>
                                            <TextBlock Text="Внимание: Отсутствуют данные для связи (Телефон/E-mail) ИЛИ не указано контактное лицо!" />
                                        </ToolTip>
                                    </iconPacks:PackIconMaterial.ToolTip>
                                </iconPacks:PackIconMaterial>
                                <TextBlock core:TextBlockHighlighter.Text="{Binding Name}"
                                           core:TextBlockHighlighter.Selection="{Binding DataContext.HighlightText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           FontWeight="SemiBold" 
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Фактический Адрес" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock core:TextBlockHighlighter.Text="{Binding Address}"
                                       core:TextBlockHighlighter.Selection="{Binding DataContext.HighlightText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                       TextWrapping="Wrap"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Контакт / Тел" Binding="{Binding Phone}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" Padding="20" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Content="ИМПОРТ ИЗ EXCEL" 
                            Command="{Binding ImportExcelCommand}" 
                            Visibility="{Binding Converter={StaticResource PermissionToVisibility}, ConverterParameter=EditCustomers}"
                            Style="{StaticResource MenuButton}" 
                            Foreground="#2E7D32"
                            Margin="0,0,10,0"/>
                    <Button Content="ЭКСПОРТ В EXCEL" 
                            Command="{Binding ExportExcelCommand}" 
                            Visibility="{Binding Converter={StaticResource PermissionToVisibility}, ConverterParameter=ViewCustomers}"
                            Style="{StaticResource MenuButton}" 
                            Foreground="#1565C0"
                            Margin="0,0,10,0"/>
                    <Button Command="{Binding BatchUpdateFromRegistryCommand}" 
                            Visibility="{Binding Converter={StaticResource PermissionToVisibility}, ConverterParameter=EditCustomers}"
                            Style="{StaticResource MenuButton}" 
                            Foreground="#9333EA">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="DatabaseSync" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="СИНХРОНИЗАЦИЯ С ФНС" VerticalAlignment="Center" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Command="{Binding DeleteCommand}" 
                            Visibility="{Binding Converter={StaticResource PermissionToVisibility}, ConverterParameter=DeleteCustomers}"
                            Style="{StaticResource MenuButton}" 
                            Foreground="#D32F2F" 
                            Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="CloseBoxOutline" Foreground="#D32F2F" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="ПОМЕТИТЬ НА УДАЛЕНИЕ" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Content="РЕДАКТИРОВАТЬ" 
                            Command="{Binding EditCommand}" 
                            Visibility="{Binding Converter={StaticResource PermissionToVisibility}, ConverterParameter=EditCustomers}"
                            Style="{StaticResource MenuButton}" 
                            Margin="0,0,10,0"/>
                    <Button Content="+ ДОБАВИТЬ КОНТРАГЕНТА" 
                            Command="{Binding AddCommand}" 
                            Visibility="{Binding Converter={StaticResource PermissionToVisibility}, ConverterParameter=EditCustomers}"
                            Style="{StaticResource PrimaryButton}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>