<UserControl x:Class="LogisticsApp.Views.InventoryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:core="clr-namespace:LogisticsApp.Core">
    <b:Interaction.Triggers>
        <b:EventTrigger EventName="Loaded">
            <b:InvokeCommandAction Command="{Binding RefreshDataCommand}" />
        </b:EventTrigger>
    </b:Interaction.Triggers>
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <core:InventoryDocumentTypeToTextConverter x:Key="InventoryDocumentTypeToTextConverter"/>
        <core:PermissionToVisibilityConverter x:Key="PermissionToVisibility"/>
    </UserControl.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ВЕРХНЯЯ ПАНЕЛЬ С ПАРАМЕТРАМИ -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="20" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" Grid.Column="0" Margin="0,0,25,0" VerticalAlignment="Center">
                        <Border Width="40" Height="40" Background="{StaticResource PrimaryLightBrush}" CornerRadius="8">
                            <iconPacks:PackIconMaterial Kind="Warehouse" Foreground="{StaticResource PrimaryDarkBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" Width="20" Height="20"/>
                        </Border>
                        <StackPanel Margin="15,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Управление складом" FontWeight="Bold" FontSize="16" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Контроль остатков и документы движения" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                    <TextBox Grid.Column="1" Style="{StaticResource ModernTextBox}"
                             mah:TextBoxHelper.Watermark="Умный поиск (Артикул, Наименование)..."
                             mah:TextBoxHelper.ClearTextButton="True"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged, Delay=500}"
                             Margin="0,0,15,0" Height="40" VerticalContentAlignment="Center"/>
                    <Button Grid.Column="2" Command="{Binding RefreshDataCommand}" Style="{StaticResource MenuButton}" ToolTip="Обновить таблицы" Height="40" Padding="15,0">
                        <iconPacks:PackIconMaterial Kind="Refresh" Width="16" Height="16" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Button>
                </Grid>

                <!-- ПЕРИОД ДЛЯ ФОРМИРОВАНИЯ ОСВ -->
                <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,-10">
                    <StackPanel Orientation="Horizontal" Margin="0,0,15,10">
                        <TextBlock Text="Период ОСВ с:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                        <DatePicker SelectedDate="{Binding DateFromFilter}" Width="130" Height="38" mah:TextBoxHelper.Watermark="ДД.ММ.ГГГГ"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,15,10">
                        <TextBlock Text="по:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                        <DatePicker SelectedDate="{Binding DateToFilter}" Width="130" Height="38" mah:TextBoxHelper.Watermark="ДД.ММ.ГГГГ"/>
                    </StackPanel>
                </WrapPanel>
            </Grid>
        </Border>

        <!-- ЦЕНТРАЛЬНАЯ ЧАСТЬ С ВКЛАДКАМИ -->
        <Border Grid.Row="1" 
                Background="{DynamicResource MahApps.Brushes.ThemeBackground}" 
                BorderBrush="{DynamicResource MahApps.Brushes.Control.Border}" 
                BorderThickness="1" 
                CornerRadius="8"
                Margin="20">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="2" Opacity="0.05"/>
            </Border.Effect>

            <TabControl x:Name="MainTabControl" mah:TabControlHelper.Underlined="TabPanel" Margin="10">
                <TabItem Header="Сводка остатков (Наличие)" mah:HeaderedControlHelper.HeaderFontSize="16">
                    <DataGrid ItemsSource="{Binding Stocks}" 
                              AutoGenerateColumns="False" 
                              IsReadOnly="True" 
                              SelectionMode="Single" 
                              Margin="10,20,10,10"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              ScrollViewer.CanContentScroll="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Склад" Binding="{Binding WarehouseName}" Width="180" FontWeight="SemiBold"/>
                            <DataGridTextColumn Header="Артикул" Binding="{Binding SKU}" Width="120" FontWeight="Bold" Foreground="#1976D2"/>
                            <DataGridTextColumn Header="Номенклатура" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTemplateColumn Header="Доступно" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="#D1FAE5" CornerRadius="4" Padding="10,4" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding AvailableQuantity}" FontWeight="Bold" Foreground="#059669" HorizontalAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="В резерве" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="#FEF3C7" CornerRadius="4" Padding="10,4" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding ReservedQuantity}" FontWeight="Bold" Foreground="#D97706" HorizontalAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Факт. остаток" Binding="{Binding TotalQuantity}" Width="140" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <TabItem Header="Документы движения (История)" mah:HeaderedControlHelper.HeaderFontSize="16">
                    <DataGrid ItemsSource="{Binding Documents}" 
                              SelectedItem="{Binding SelectedDocument}" 
                              AutoGenerateColumns="False" 
                              IsReadOnly="True" 
                              SelectionMode="Single"
                              Margin="10,20,10,10"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              ScrollViewer.CanContentScroll="True">
                        <DataGrid.InputBindings>
                            <MouseBinding Gesture="LeftDoubleClick" Command="{Binding EditDocumentCommand}"/>
                        </DataGrid.InputBindings>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="№ Док." Binding="{Binding DocumentID}" Width="100" FontWeight="Bold"/>
                            <DataGridTextColumn Header="Дата" Binding="{Binding DocumentDate, StringFormat=dd.MM.yyyy HH:mm}" Width="160" FontWeight="SemiBold"/>
                            <DataGridTextColumn Header="Склад" Binding="{Binding Warehouse.Name}" Width="250" FontWeight="SemiBold"/>
                            <DataGridTemplateColumn Header="Операция" Width="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="4" Padding="10,4" HorizontalAlignment="Left">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#E0F2FE"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Type}" Value="WriteOff">
                                                            <Setter Property="Background" Value="#FEE2E2"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Type}" Value="Request">
                                                            <Setter Property="Background" Value="#FEF3C7"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Type, Converter={StaticResource InventoryDocumentTypeToTextConverter}}" FontWeight="Bold" HorizontalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#0284C7"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Type}" Value="WriteOff">
                                                                <Setter Property="Foreground" Value="#DC2626"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}" Value="Request">
                                                                <Setter Property="Foreground" Value="#D97706"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Основание / Комментарий" Binding="{Binding Reason}" Width="*"/>
                            <DataGridTemplateColumn Header="Проведен" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <iconPacks:PackIconMaterial Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <iconPacks:PackIconMaterial.Style>
                                                <Style TargetType="iconPacks:PackIconMaterial">
                                                    <Setter Property="Kind" Value="CheckCircle"/>
                                                    <Setter Property="Foreground" Value="#10B981"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPosted}" Value="False">
                                                            <Setter Property="Kind" Value="ClockOutline"/>
                                                            <Setter Property="Foreground" Value="#9CA3AF"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </iconPacks:PackIconMaterial.Style>
                                        </iconPacks:PackIconMaterial>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
            </TabControl>
        </Border>

        <!-- ЕДИНЫЙ ПОДВАЛ (ОТЧЕТЫ И КНОПКИ ДЕЙСТВИЙ) -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" Padding="20" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- ЛЕВАЯ ПАНЕЛЬ С КНОПКОЙ ОТЧЕТОВ -->
                <WrapPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
                    <mah:DropDownButton Content="ОТЧЕТЫ И ПЕЧАТЬ" 
                                        Margin="0,5,10,5"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="#2E7D32"
                                        FontWeight="SemiBold"
                                        FontSize="14"
                                        Cursor="Hand"
                                        ToolTip="Аналитические складские отчеты">
                        <mah:DropDownButton.Icon>
                            <iconPacks:PackIconMaterial Kind="ChartBoxOutline" Margin="0,0,8,0" Foreground="#2E7D32"/>
                        </mah:DropDownButton.Icon>
                        <mah:DropDownButton.Items>
                            <MenuItem Header="Оборотно-сальдовая ведомость (ОСВ)" Command="{Binding PrintInventoryBalanceCommand}">
                                <MenuItem.Icon>
                                    <iconPacks:PackIconMaterial Kind="FileExcelBox" Foreground="#2E7D32"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Анализ дефицита товаров" Command="{Binding PrintDeficitCommand}">
                                <MenuItem.Icon>
                                    <iconPacks:PackIconMaterial Kind="AlertCircleOutline" Foreground="#D32F2F"/>
                                </MenuItem.Icon>
                            </MenuItem>
                        </mah:DropDownButton.Items>
                    </mah:DropDownButton>
                </WrapPanel>

                <!-- ПРАВАЯ ПАНЕЛЬ С КНОПКАМИ ДЕЙСТВИЙ -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Visibility="{Binding Converter={StaticResource PermissionToVisibility}, ConverterParameter=EditInventory}">
                    <Button Content="+ СОЗДАТЬ ДОКУМЕНТ ОПРИХОДОВАНИЯ" Command="{Binding AddDocumentCommand}" Margin="0,5,0,5">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedIndex, ElementName=MainTabControl}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="ОТКРЫТЬ ДОКУМЕНТ" Command="{Binding EditDocumentCommand}" Margin="0,5,10,5">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MenuButton}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedIndex, ElementName=MainTabControl}" Value="1">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="+ СОЗДАТЬ ДОКУМЕНТ" Command="{Binding AddDocumentCommand}" Margin="0,5,0,5">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedIndex, ElementName=MainTabControl}" Value="1">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ИНДИКАТОР ЗАГРУЗКИ -->
        <ProgressBar Grid.Row="1" IsIndeterminate="True" VerticalAlignment="Top" Height="4" BorderThickness="0"
                     Foreground="{StaticResource PrimaryBrush}" Background="Transparent"
                     Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
    </Grid>
</UserControl>