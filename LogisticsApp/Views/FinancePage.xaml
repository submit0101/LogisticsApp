<UserControl x:Class="LogisticsApp.Views.FinancePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:core="clr-namespace:LogisticsApp.Core">
    <b:Interaction.Triggers>
        <b:EventTrigger EventName="Loaded">
            <b:InvokeCommandAction Command="{Binding LoadDebtsCommand}" />
            <b:InvokeCommandAction Command="{Binding LoadPaymentsCommand}" />
        </b:EventTrigger>
    </b:Interaction.Triggers>
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <core:PermissionToVisibilityConverter x:Key="PermissionToVisibility"/>
    </UserControl.Resources>
    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="20" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" Grid.Column="0" Margin="0,0,25,0" VerticalAlignment="Center">
                        <Border Width="40" Height="40" Background="{StaticResource PrimaryLightBrush}" CornerRadius="8">
                            <iconPacks:PackIconMaterial Kind="CashRegister" Foreground="{StaticResource PrimaryDarkBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" Width="20" Height="20"/>
                        </Border>
                        <StackPanel Margin="15,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Казначейство и Финансы" FontWeight="Bold" FontSize="16" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Контроль взаиморасчетов и платежи" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                    <Grid Grid.Column="1" Margin="0,0,15,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource ModernTextBox}"
                                 mah:TextBoxHelper.Watermark="Интеллектуальный поиск (ИНН, Контрагент)..."
                                 mah:TextBoxHelper.ClearTextButton="True"
                                 Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged, Delay=500}"
                                 Margin="0,0,15,0" Height="40" VerticalContentAlignment="Center"/>
                        <Button Grid.Column="1" Command="{Binding LoadDebtsCommand}" Style="{StaticResource MenuButton}" ToolTip="Обновить таблицу" Height="40" Padding="15,0">
                            <iconPacks:PackIconMaterial Kind="Refresh" Width="16" Height="16" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Button>
                    </Grid>
                </Grid>
                <!-- ПЕРИОД ДЛЯ ФОРМИРОВАНИЯ ФИН. ОТЧЕТОВ -->
                <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,-10">
                    <StackPanel Orientation="Horizontal" Margin="0,0,15,10">
                        <TextBlock Text="Период отчетов с:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                        <DatePicker SelectedDate="{Binding DateFromFilter}" Width="130" Height="38" mah:TextBoxHelper.Watermark="ДД.ММ.ГГГГ"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,15,10">
                        <TextBlock Text="по:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                        <DatePicker SelectedDate="{Binding DateToFilter}" Width="130" Height="38" mah:TextBoxHelper.Watermark="ДД.ММ.ГГГГ"/>
                    </StackPanel>
                </WrapPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" 
                Background="{DynamicResource MahApps.Brushes.ThemeBackground}" 
                BorderBrush="{DynamicResource MahApps.Brushes.Control.Border}" 
                BorderThickness="1" 
                CornerRadius="8"
                Margin="20">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="2" Opacity="0.05"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="20,20,20,10">
                    <ComboBox x:Name="ViewSelector" SelectedIndex="0" Width="280" Margin="0,0,15,10" Height="38" VerticalContentAlignment="Center" Style="{StaticResource MahApps.Styles.ComboBox}">
                        <ComboBoxItem Content="Взаиморасчеты (Долги)"/>
                        <ComboBoxItem Content="История платежей (ПКО)"/>
                    </ComboBox>
                    <Border Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1" CornerRadius="6" Padding="15,8" Margin="0,0,15,10">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="AlertCircleOutline" Foreground="#DC2626" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="ДЕБИТОРСКАЯ ЗАДОЛЖЕННОСТЬ:" FontSize="12" FontWeight="Bold" Foreground="#991B1B" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding TotalReceivables, StringFormat={}{0:N2} ₽}" FontSize="16" FontWeight="ExtraBold" Foreground="#DC2626" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#ECFDF5" BorderBrush="#6EE7B7" BorderThickness="1" CornerRadius="6" Padding="15,8" Margin="0,0,15,10">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="CashCheck" Foreground="#059669" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="АВАНСЫ КЛИЕНТОВ (КРЕДИТОРСКАЯ):" FontSize="12" FontWeight="Bold" Foreground="#065F46" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding TotalAdvances, StringFormat={}{0:N2} ₽}" FontSize="16" FontWeight="ExtraBold" Foreground="#059669" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <Grid Grid.Row="1">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedIndex, ElementName=ViewSelector}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <!-- ИСПРАВЛЕНИЕ: Добавлен SelectedItem="{Binding SelectedDebt}" для акта сверки -->
                    <DataGrid ItemsSource="{Binding Debts}" 
                              SelectedItem="{Binding SelectedDebt}"
                              AutoGenerateColumns="False" 
                              IsReadOnly="True" 
                              SelectionMode="Single" 
                              Margin="10,0,10,10"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              ScrollViewer.CanContentScroll="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Контрагент" Binding="{Binding CustomerName}" Width="*" FontWeight="SemiBold" Foreground="#1976D2"/>
                            <DataGridTextColumn Header="ИНН" Binding="{Binding INN}" Width="120" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <DataGridTemplateColumn Header="Отгружено на сумму" Width="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding TotalShipped, StringFormat={}{0:N2} ₽}" FontWeight="Bold" Foreground="#1F2937" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Оплачено" Width="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding TotalPaid, StringFormat={}{0:N2} ₽}" FontWeight="Bold" Foreground="#059669" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Состояние расчетов" Width="200">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Border Background="#FEE2E2" CornerRadius="4" Padding="10,4" HorizontalAlignment="Left" Visibility="{Binding IsDebt, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="{Binding CurrentDebt, StringFormat=Долг: {0:N2} ₽}" FontWeight="Bold" Foreground="#DC2626"/>
                                            </Border>
                                            <Border Background="#D1FAE5" CornerRadius="4" Padding="10,4" HorizontalAlignment="Left" Visibility="{Binding IsAdvance, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="{Binding AdvanceAmount, StringFormat=Аванс: {0:N2} ₽}" FontWeight="Bold" Foreground="#059669"/>
                                            </Border>
                                            <Border Background="#F3F4F6" CornerRadius="4" Padding="10,4" HorizontalAlignment="Left" Visibility="{Binding IsSettled, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="Взаиморасчеты закрыты" FontWeight="Bold" Foreground="#6B7280"/>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedIndex, ElementName=ViewSelector}" Value="1">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <DataGrid ItemsSource="{Binding Payments}" 
                              SelectedItem="{Binding SelectedPayment}" 
                              AutoGenerateColumns="False" 
                              IsReadOnly="True" 
                              SelectionMode="Single"
                              Margin="10,0,10,10"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              ScrollViewer.CanContentScroll="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Дата" Binding="{Binding Date, StringFormat=dd.MM.yyyy HH:mm}" Width="150" FontWeight="SemiBold"/>
                            <DataGridTextColumn Header="Контрагент" Binding="{Binding Customer.Name}" Width="300" FontWeight="SemiBold" Foreground="#1976D2"/>
                            <DataGridTextColumn Header="Основание" Binding="{Binding Description}" Width="*"/>
                            <DataGridTemplateColumn Header="Сумма (₽)" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Amount, StringFormat={}{0:N2}}" FontWeight="Bold" Foreground="#059669" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" Padding="20" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- МЕНЮ ОТЧЕТОВ -->
                <WrapPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
                    <mah:DropDownButton Content="ФИНАНСОВЫЕ ОТЧЕТЫ" 
                                        Margin="0,5,10,5"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="#2E7D32"
                                        FontWeight="SemiBold"
                                        FontSize="14"
                                        Cursor="Hand"
                                        ToolTip="Документы и выгрузки">
                        <mah:DropDownButton.Icon>
                            <iconPacks:PackIconMaterial Kind="FileExcelBox" Margin="0,0,8,0" Foreground="#2E7D32"/>
                        </mah:DropDownButton.Icon>
                        <mah:DropDownButton.Items>
                            <MenuItem Header="Акт сверки по выбранному контрагенту" Command="{Binding PrintReconciliationCommand}">
                                <MenuItem.Icon>
                                    <iconPacks:PackIconMaterial Kind="HandshakeOutline" Foreground="#1976D2"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Header="Сводный реестр поступлений ДДС" Command="{Binding PrintCashFlowCommand}">
                                <MenuItem.Icon>
                                    <iconPacks:PackIconMaterial Kind="CashMultiple" Foreground="#059669"/>
                                </MenuItem.Icon>
                            </MenuItem>
                        </mah:DropDownButton.Items>
                    </mah:DropDownButton>
                </WrapPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="+ ЗАРЕГИСТРИРОВАТЬ ПЛАТЕЖ" 
                            Command="{Binding AddPaymentCommand}" 
                            Visibility="{Binding Converter={StaticResource PermissionToVisibility}, ConverterParameter=EditFinance}"
                            Style="{StaticResource PrimaryButton}"/>
                </StackPanel>
            </Grid>
        </Border>

        <ProgressBar Grid.Row="1" IsIndeterminate="True" VerticalAlignment="Top" Height="4" BorderThickness="0"
                     Foreground="{StaticResource PrimaryBrush}" Background="Transparent"
                     Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
    </Grid>
</UserControl>