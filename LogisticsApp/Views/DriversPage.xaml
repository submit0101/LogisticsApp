<UserControl x:Class="LogisticsApp.Views.DriversPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:local="clr-namespace:LogisticsApp.Views"
             xmlns:core="clr-namespace:LogisticsApp.Core"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1200">
    <b:Interaction.Triggers>
        <b:EventTrigger EventName="Loaded">
            <b:InvokeCommandAction Command="{Binding LoadDataCommand}" />
        </b:EventTrigger>
    </b:Interaction.Triggers>
    <UserControl.Resources>
        <local:DriverStatusToColorConverter x:Key="DriverStatusToColorConverter"/>
        <local:DriverStatusToTextConverter x:Key="DriverStatusToTextConverter"/>
        <core:PermissionToVisibilityConverter x:Key="PermissionToVisibility"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:DriverExpiryWarningConverter x:Key="DriverExpiryWarningConverter"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="20" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" Grid.Column="0" Margin="0,0,25,0" VerticalAlignment="Center">
                        <Border Width="40" Height="40" Background="{StaticResource PrimaryLightBrush}" CornerRadius="8">
                            <iconPacks:PackIconMaterial Kind="CardAccountDetailsOutline" Foreground="{StaticResource PrimaryDarkBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" Width="20" Height="20"/>
                        </Border>
                        <StackPanel Margin="15,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Сотрудники" FontWeight="Bold" FontSize="16" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="База водителей" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                    <TextBox Grid.Column="1" Style="{StaticResource ModernTextBox}"
                             mah:TextBoxHelper.Watermark="Умный поиск (ФИО, ВУ, Телефон)..."
                             mah:TextBoxHelper.ClearTextButton="True"
                             Text="{Binding HighlightText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,15,0" Height="40" VerticalContentAlignment="Center"/>
                    <Button Grid.Column="2" Command="{Binding LoadDataCommand}" Style="{StaticResource MenuButton}" ToolTip="Обновить из БД" Height="40" Padding="15,0">
                        <iconPacks:PackIconMaterial Kind="Refresh" Width="16" Height="16" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Button>
                </Grid>
                <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,-10">
                    <ComboBox Width="180" 
                              ItemsSource="{Binding AvailableStatuses}" 
                              SelectedItem="{Binding SelectedStatusFilter}" 
                              mah:TextBoxHelper.Watermark="Все статусы"
                              Margin="0,0,15,10" Height="38" VerticalContentAlignment="Center"
                              Style="{StaticResource MahApps.Styles.ComboBox}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource DriverStatusToTextConverter}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <ComboBox Width="160" 
                              ItemsSource="{Binding AvailableCategories}" 
                              SelectedItem="{Binding SelectedCategoryFilter}" 
                              mah:TextBoxHelper.Watermark="Категория прав"
                              Margin="0,0,15,10" Height="38" VerticalContentAlignment="Center"
                              Style="{StaticResource MahApps.Styles.ComboBox}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,15,10">
                        <TextBlock Text="Дата найма с:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                        <DatePicker SelectedDate="{Binding EmploymentDateFrom}" Width="130" Height="38" mah:TextBoxHelper.Watermark="ДД.ММ.ГГГГ"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,15,10">
                        <TextBlock Text="по:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                        <DatePicker SelectedDate="{Binding EmploymentDateTo}" Width="130" Height="38" mah:TextBoxHelper.Watermark="ДД.ММ.ГГГГ"/>
                    </StackPanel>
                </WrapPanel>
            </Grid>
        </Border>
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Drivers}"
                  SelectedItem="{Binding SelectedDriver}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  Margin="20"
                  EnableRowVirtualization="True"
                  EnableColumnVirtualization="True"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  ScrollViewer.CanContentScroll="True">
            <DataGrid.InputBindings>
                <MouseBinding Gesture="LeftDoubleClick" Command="{Binding EditDriverCommand}"/>
            </DataGrid.InputBindings>
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="!" Width="40" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <iconPacks:PackIconMaterial Kind="AlertOctagon" Foreground="#EF4444" Width="16" Height="16" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <iconPacks:PackIconMaterial.Visibility>
                                    <MultiBinding Converter="{StaticResource DriverExpiryWarningConverter}">
                                        <Binding Path="LicenseExpirationDate"/>
                                        <Binding Path="MedicalCertificateExpiration"/>
                                        <Binding Path="DataContext.ExpiryWarningDays" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                    </MultiBinding>
                                </iconPacks:PackIconMaterial.Visibility>
                                <iconPacks:PackIconMaterial.ToolTip>
                                    <ToolTip>
                                        <TextBlock Text="Внимание! Срок действия документов (ВУ или Медсправка) истекает или уже истек!" />
                                    </ToolTip>
                                </iconPacks:PackIconMaterial.ToolTip>
                            </iconPacks:PackIconMaterial>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Аватар" Width="70" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Width="36" Height="36" CornerRadius="18">
                                <Border.Background>
                                    <ImageBrush ImageSource="{Binding PhotoPath, TargetNullValue='pack://application:,,,/Assets/avatar.jpg'}" Stretch="UniformToFill"/>
                                </Border.Background>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="ФИО Водителя" Width="250">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock core:TextBlockHighlighter.Text="{Binding FullName}"
                                       core:TextBlockHighlighter.Selection="{Binding DataContext.HighlightText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Телефон" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock core:TextBlockHighlighter.Text="{Binding Phone}"
                                       core:TextBlockHighlighter.Selection="{Binding DataContext.HighlightText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Номер ВУ" Binding="{Binding LicenseNumber}" Width="130"/>
                <DataGridTextColumn Header="Категории" Binding="{Binding LicenseCategories}" Width="100"/>
                <DataGridTextColumn Header="Дата найма" Binding="{Binding EmploymentDate, StringFormat=dd.MM.yyyy}" Width="110"/>
                <DataGridTemplateColumn Header="Статус" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Padding="10,5" CornerRadius="4" HorizontalAlignment="Left"
                                    Background="{Binding Status, Converter={StaticResource DriverStatusToColorConverter}}">
                                <TextBlock Text="{Binding Status, Converter={StaticResource DriverStatusToTextConverter}}" 
                                           Foreground="White" FontWeight="SemiBold" FontSize="11"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" Padding="20" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Content="ЭКСПОРТ В EXCEL" 
                            Command="{Binding ExportExcelCommand}" 
                            Visibility="{Binding Converter={StaticResource PermissionToVisibility}, ConverterParameter=ViewDrivers}"
                            Style="{StaticResource MenuButton}" 
                            Foreground="#1565C0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Command="{Binding DeleteDriverCommand}" 
                            Visibility="{Binding Converter={StaticResource PermissionToVisibility}, ConverterParameter=DeleteDrivers}"
                            Style="{StaticResource MenuButton}" 
                            Foreground="#D32F2F" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="CloseBoxOutline" Foreground="#D32F2F" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="ПОМЕТИТЬ НА УДАЛЕНИЕ" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Content="РЕДАКТИРОВАТЬ" 
                            Command="{Binding EditDriverCommand}" 
                            Visibility="{Binding Converter={StaticResource PermissionToVisibility}, ConverterParameter=EditDrivers}"
                            Style="{StaticResource MenuButton}" Margin="0,0,10,0"/>
                    <Button Content="+ ДОБАВИТЬ ВОДИТЕЛЯ" 
                            Command="{Binding AddDriverCommand}" 
                            Visibility="{Binding Converter={StaticResource PermissionToVisibility}, ConverterParameter=EditDrivers}"
                            Style="{StaticResource PrimaryButton}"/>
                </StackPanel>
            </Grid>
        </Border>
        <ProgressBar Grid.Row="1" IsIndeterminate="True" VerticalAlignment="Top" Height="4" BorderThickness="0"
                     Foreground="{StaticResource PrimaryBrush}" Background="Transparent"
                     Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
    </Grid>
</UserControl>