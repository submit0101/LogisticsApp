<UserControl x:Class="LogisticsApp.Views.VehiclesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:local="clr-namespace:LogisticsApp.Views"
             xmlns:core="clr-namespace:LogisticsApp.Core"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1200">

    <b:Interaction.Triggers>
        <b:EventTrigger EventName="Loaded">
            <b:InvokeCommandAction Command="{Binding LoadDataCommand}" />
        </b:EventTrigger>
    </b:Interaction.Triggers>

    <UserControl.Resources>
        <local:VehicleStatusToColorConverter x:Key="VehicleStatusToColorConverter"/>
        <local:VehicleStatusToTextConverter x:Key="VehicleStatusToTextConverter"/>
        <core:PermissionToVisibilityConverter x:Key="PermissionToVisibility"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="20" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.Column="0" Margin="0,0,25,0" VerticalAlignment="Center">
                        <Border Width="40" Height="40" Background="{StaticResource PrimaryLightBrush}" CornerRadius="8">
                            <iconPacks:PackIconMaterial Kind="TruckOutline" Foreground="{StaticResource PrimaryDarkBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" Width="20" Height="20"/>
                        </Border>
                        <StackPanel Margin="15,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Автопарк" FontWeight="Bold" FontSize="16" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Транспортные средства" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBox Grid.Column="1" Style="{StaticResource ModernTextBox}"
                             mah:TextBoxHelper.Watermark="Умный поиск (Номер, Модель, VIN)..."
                             mah:TextBoxHelper.ClearTextButton="True"
                             Text="{Binding HighlightText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,15,0" Height="40" VerticalContentAlignment="Center"/>

                    <Button Grid.Column="2" Command="{Binding LoadDataCommand}" Style="{StaticResource MenuButton}" ToolTip="Обновить из БД" Height="40" Padding="15,0">
                        <iconPacks:PackIconMaterial Kind="Refresh" Width="16" Height="16" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Button>
                </Grid>

                <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,-10">
                    <ComboBox Width="200" 
                              ItemsSource="{Binding AvailableStatuses}" 
                              SelectedItem="{Binding SelectedStatusFilter}" 
                              mah:TextBoxHelper.Watermark="Статус ТС"
                              Margin="0,0,15,10" Height="38" VerticalContentAlignment="Center"
                              Style="{StaticResource MahApps.Styles.ComboBox}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource VehicleStatusToTextConverter}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <ComboBox Width="200" 
                              ItemsSource="{Binding AvailableFridgeFilters}" 
                              SelectedItem="{Binding SelectedFridgeFilterStr}" 
                              Margin="0,0,15,10" Height="38" VerticalContentAlignment="Center"
                              Style="{StaticResource MahApps.Styles.ComboBox}"/>
                </WrapPanel>
            </Grid>
        </Border>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Vehicles}"
                  SelectedItem="{Binding SelectedVehicle}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  Margin="20"
                  EnableRowVirtualization="True"
                  EnableColumnVirtualization="True"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  ScrollViewer.CanContentScroll="True">

            <DataGrid.InputBindings>
                <MouseBinding Gesture="LeftDoubleClick" Command="{Binding EditVehicleCommand}"/>
            </DataGrid.InputBindings>

            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Гос. номер" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock core:TextBlockHighlighter.Text="{Binding RegNumber}"
                                       core:TextBlockHighlighter.Selection="{Binding DataContext.HighlightText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                       FontWeight="Bold" Foreground="#1976D2" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Модель" Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock core:TextBlockHighlighter.Text="{Binding Model}"
                                       core:TextBlockHighlighter.Selection="{Binding DataContext.HighlightText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="VIN" Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock core:TextBlockHighlighter.Text="{Binding VIN}"
                                       core:TextBlockHighlighter.Selection="{Binding DataContext.HighlightText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Год" Binding="{Binding Year}" Width="80"/>

                <DataGridTemplateColumn Header="Грузоподъемность" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding CapacityKG, StringFormat={}{0} кг}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding CapacityM3, StringFormat={}{0:F1} м³}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Пробег" Binding="{Binding Mileage, StringFormat={}{0:N0} км}" Width="120"/>

                <DataGridTemplateColumn Header="Реф." Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <iconPacks:PackIconMaterial Kind="Snowflake" Foreground="#2196F3" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding IsFridge, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Статус" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Padding="10,5" CornerRadius="4" HorizontalAlignment="Left" Background="{Binding Status, Converter={StaticResource VehicleStatusToColorConverter}}">
                                <TextBlock Text="{Binding Status, Converter={StaticResource VehicleStatusToTextConverter}}" Foreground="White" FontWeight="SemiBold" FontSize="11"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" Padding="20" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Content="ИМПОРТ ИЗ EXCEL" 
                            Command="{Binding ImportExcelCommand}" 
                            Visibility="{Binding Converter={StaticResource PermissionToVisibility}, ConverterParameter=EditVehicles}"
                            Style="{StaticResource MenuButton}" 
                            Foreground="#2E7D32"
                            Margin="0,0,10,0"/>

                    <Button Content="ЭКСПОРТ В EXCEL" 
                            Command="{Binding ExportExcelCommand}" 
                            Visibility="{Binding Converter={StaticResource PermissionToVisibility}, ConverterParameter=ViewVehicles}"
                            Style="{StaticResource MenuButton}" 
                            Foreground="#1565C0"
                            Margin="0,0,10,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Command="{Binding DeleteVehicleCommand}" 
                            Visibility="{Binding Converter={StaticResource PermissionToVisibility}, ConverterParameter=DeleteVehicles}"
                            Style="{StaticResource MenuButton}" 
                            Foreground="#D32F2F" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="CloseBoxOutline" Foreground="#D32F2F" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="ПОМЕТИТЬ НА УДАЛЕНИЕ" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Content="РЕДАКТИРОВАТЬ" 
                            Command="{Binding EditVehicleCommand}" 
                            Visibility="{Binding Converter={StaticResource PermissionToVisibility}, ConverterParameter=EditVehicles}"
                            Style="{StaticResource MenuButton}" Margin="0,0,10,0"/>

                    <Button Content="+ ДОБАВИТЬ ТС" 
                            Command="{Binding AddVehicleCommand}" 
                            Visibility="{Binding Converter={StaticResource PermissionToVisibility}, ConverterParameter=EditVehicles}"
                            Style="{StaticResource PrimaryButton}"/>
                </StackPanel>
            </Grid>
        </Border>

        <ProgressBar Grid.Row="1" IsIndeterminate="True" VerticalAlignment="Top" Height="4" BorderThickness="0"
                     Foreground="{StaticResource PrimaryBrush}" Background="Transparent"
                     Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
    </Grid>
</UserControl>