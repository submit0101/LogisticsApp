<mah:MetroWindow x:Class="LogisticsApp.Views.Windows.DriverEditWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:viewmodels="clr-namespace:LogisticsApp.ViewModels.Windows"
                 xmlns:enums="clr-namespace:LogisticsApp.Models.Enums"
                 xmlns:local="clr-namespace:LogisticsApp.Views.Windows"
                 xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
                 xmlns:behaviors="clr-namespace:LogisticsApp.Services"
                 Title="Карточка Водителя" Height="720" Width="1000"
                 WindowStartupLocation="CenterScreen"
                 Background="{StaticResource BackgroundBrush}"
                 GlowBrush="{StaticResource PrimaryBrush}"
                 BorderThickness="1">

    <mah:MetroWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:DriverInverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <local:DriverStatusToTextConverterLocal x:Key="DriverStatusToTextConverter"/>

        <!-- ШАБЛОН ОТОБРАЖЕНИЯ ОШИБОК -->
        <ControlTemplate x:Key="BottomErrorTemplate">
            <StackPanel>
                <AdornedElementPlaceholder x:Name="placeholder"/>
                <TextBlock Text="{Binding [0].ErrorContent}" 
                           Foreground="#D32F2F" FontSize="11" Margin="2,2,0,-18" FontStyle="Italic" TextWrapping="Wrap"/>
            </StackPanel>
        </ControlTemplate>

        <Style TargetType="TextBox" BasedOn="{StaticResource ModernTextBox}">
            <Setter Property="Validation.ErrorTemplate" Value="{StaticResource BottomErrorTemplate}"/>
        </Style>

        <Style TargetType="ComboBox" BasedOn="{StaticResource MahApps.Styles.ComboBox}">
            <Setter Property="Validation.ErrorTemplate" Value="{StaticResource BottomErrorTemplate}"/>
        </Style>

        <Style TargetType="DatePicker" BasedOn="{StaticResource MahApps.Styles.DatePicker}">
            <Setter Property="Validation.ErrorTemplate" Value="{StaticResource BottomErrorTemplate}"/>
        </Style>
    </mah:MetroWindow.Resources>

    <Grid IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ЛЕВАЯ ПАНЕЛЬ (Аватар и Статус) -->
        <Border Grid.Row="0" Grid.Column="0" Background="{StaticResource SurfaceBrush}" Margin="15,15,5,15" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="25">
            <StackPanel>
                <Border Width="180" Height="180" CornerRadius="90" BorderThickness="3" BorderBrush="{StaticResource BorderBrush}" Margin="0,10,0,20">
                    <Border.Background>
                        <ImageBrush ImageSource="{Binding PhotoPath, TargetNullValue='pack://application:,,,/Assets/avatar.jpg'}" Stretch="UniformToFill"/>
                    </Border.Background>
                </Border>

                <Button Content="Загрузить фото" Command="{Binding UploadPhotoCommand}" Style="{StaticResource MenuButton}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,0,10" HorizontalContentAlignment="Center"/>
                <Button Content="Удалить фото" Command="{Binding RemovePhotoCommand}" Style="{StaticResource MenuButton}" Foreground="#D32F2F" Margin="0,0,0,30" HorizontalContentAlignment="Center"/>

                <TextBlock Text="Текущий статус:" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <ComboBox ItemsSource="{Binding AvailableStatuses}" SelectedItem="{Binding Status, ValidatesOnDataErrors=True}" Margin="0,0,0,25">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource DriverStatusToTextConverter}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Text="Дата найма:" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <DatePicker SelectedDate="{Binding EmploymentDate}" Height="38"/>
            </StackPanel>
        </Border>

        <!-- ПРАВАЯ ПАНЕЛЬ (Вкладки) -->
        <TabControl Grid.Row="0" Grid.Column="1" Margin="5,15,15,0" mah:TabControlHelper.Underlined="TabPanel" Background="Transparent" BorderThickness="0">

            <TabItem Header="Личные данные" mah:HeaderedControlHelper.HeaderFontSize="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Margin="5,10,5,5" Padding="25" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Фамилия:" VerticalAlignment="Center" Margin="0,0,10,25" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" Margin="0,0,0,25">
                                <b:Interaction.Behaviors>
                                    <behaviors:NameMaskBehavior />
                                </b:Interaction.Behaviors>
                            </TextBox>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Имя:" VerticalAlignment="Center" Margin="0,0,10,25" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" Margin="0,0,0,25">
                                <b:Interaction.Behaviors>
                                    <behaviors:NameMaskBehavior />
                                </b:Interaction.Behaviors>
                            </TextBox>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Отчество:" VerticalAlignment="Center" Margin="0,0,10,25" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding MiddleName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,25">
                                <b:Interaction.Behaviors>
                                    <behaviors:NameMaskBehavior />
                                </b:Interaction.Behaviors>
                            </TextBox>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Телефон:" VerticalAlignment="Center" Margin="0,0,10,25" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" Margin="0,0,0,25" Width="250" HorizontalAlignment="Left" mah:TextBoxHelper.Watermark="+7 ...">
                                <b:Interaction.Behaviors>
                                    <behaviors:PhoneMaskBehavior MaskType="0"/>
                                </b:Interaction.Behaviors>
                            </TextBox>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="E-mail:" VerticalAlignment="Center" Margin="0,0,10,25" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" Margin="0,0,0,25" mah:TextBoxHelper.Watermark="driver@domain.com"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Экстренный контакт:" VerticalAlignment="Center" Margin="0,0,10,25" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                            <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding EmergencyContact, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,25" mah:TextBoxHelper.Watermark="+7 ...">
                                <b:Interaction.Behaviors>
                                    <behaviors:PhoneMaskBehavior MaskType="0"/>
                                </b:Interaction.Behaviors>
                            </TextBox>

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Паспортные данные:" VerticalAlignment="Center" Margin="0,8,10,25" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                            <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding PassportData, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,25" mah:TextBoxHelper.Watermark="12 34 567890">
                                <b:Interaction.Behaviors>
                                    <behaviors:PassportMaskBehavior />
                                </b:Interaction.Behaviors>
                            </TextBox>
                        </Grid>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Документы и ВУ" mah:HeaderedControlHelper.HeaderFontSize="14">
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Margin="5,10,5,5" Padding="25" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Номер ВУ:" VerticalAlignment="Center" Margin="0,0,10,25" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding LicenseNumber, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" Margin="0,0,0,25" Width="250" HorizontalAlignment="Left" mah:TextBoxHelper.Watermark="12 34 567890">
                            <b:Interaction.Behaviors>
                                <behaviors:PassportMaskBehavior />
                            </b:Interaction.Behaviors>
                        </TextBox>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Категории:" VerticalAlignment="Center" Margin="0,0,10,25" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                        <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding AvailableCategories}" SelectedItem="{Binding LicenseCategories, ValidatesOnDataErrors=True}" Margin="0,0,0,25" Width="250" HorizontalAlignment="Left" mah:TextBoxHelper.Watermark="Выберите категорию..."/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="ВУ действительно до:" VerticalAlignment="Center" Margin="0,0,10,25" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                        <DatePicker Grid.Row="2" Grid.Column="1" SelectedDate="{Binding LicenseExpirationDate}" Margin="0,0,0,25" Width="250" HorizontalAlignment="Left"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Мед. справка (номер):" VerticalAlignment="Center" Margin="0,0,10,25" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding MedicalCertificateNumber, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,25" Width="250" HorizontalAlignment="Left" mah:TextBoxHelper.Watermark="003-В/у № 000000">
                            <b:Interaction.Behaviors>
                                <behaviors:MedCertMaskBehavior />
                            </b:Interaction.Behaviors>
                        </TextBox>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Справка действительна до:" VerticalAlignment="Center" Margin="0,0,10,25" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                        <DatePicker Grid.Row="4" Grid.Column="1" SelectedDate="{Binding MedicalCertificateExpiration}" Margin="0,0,0,25" Width="250" HorizontalAlignment="Left"/>
                    </Grid>
                </Border>
            </TabItem>

            <TabItem Header="Служебная информация" mah:HeaderedControlHelper.HeaderFontSize="14">
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Margin="5,10,5,5" Padding="25" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Дата увольнения:" VerticalAlignment="Center" Margin="0,0,10,25" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                        <DatePicker Grid.Row="0" Grid.Column="1" SelectedDate="{Binding DismissalDate}" Margin="0,0,0,25" Width="250" HorizontalAlignment="Left"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Заметки / Характеристика:" VerticalAlignment="Top" Margin="0,8,10,25" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,25" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>

        <!-- ПОДВАЛ (Кнопки сохранения) -->
        <Border Grid.Row="1" Grid.ColumnSpan="2" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="20,15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="ОТМЕНА" Command="{Binding CancelCommand}" Style="{StaticResource MenuButton}" Margin="0,0,15,0" FontWeight="SemiBold"/>
                <Button Content="СОХРАНИТЬ И ЗАКРЫТЬ" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButton}" Width="220"/>
            </StackPanel>
        </Border>

        <!-- Индикатор загрузки поверх окна -->
        <Border Grid.RowSpan="2" Grid.ColumnSpan="2" Background="#80FFFFFF" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ProgressBar IsIndeterminate="True" Width="250" Height="6" BorderThickness="0" Foreground="{StaticResource PrimaryBrush}" Background="Transparent"/>
        </Border>
    </Grid>
</mah:MetroWindow>