<mah:MetroWindow x:Class="LogisticsApp.Views.Windows.OrderEditWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                 xmlns:local="clr-namespace:LogisticsApp.Views.Windows"
                 xmlns:core="clr-namespace:LogisticsApp.Core"
                 Title="Документ: Заказ покупателя"
                 Height="820" Width="1200"
                 WindowStartupLocation="CenterScreen"
                 Background="{StaticResource BackgroundBrush}"
                 GlowBrush="{StaticResource PrimaryBrush}"
                 BorderThickness="1">

    <mah:MetroWindow.Resources>
        <local:OrderInverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <core:OrderStatusToTextConverter x:Key="OrderStatusToTextConverter"/>
        <core:OrderStatusToColorConverter x:Key="OrderStatusToColorConverter"/>
        <local:OrderPriorityToTextConverter x:Key="OrderPriorityToTextConverter"/>

        <ControlTemplate x:Key="BottomErrorTemplate">
            <StackPanel>
                <AdornedElementPlaceholder x:Name="placeholder"/>
                <TextBlock Text="{Binding [0].ErrorContent}" Foreground="#D32F2F" FontSize="11" Margin="2,2,0,-18" FontStyle="Italic" TextWrapping="Wrap"/>
            </StackPanel>
        </ControlTemplate>
        <Style TargetType="TextBox" BasedOn="{StaticResource ModernTextBox}">
            <Setter Property="Validation.ErrorTemplate" Value="{StaticResource BottomErrorTemplate}"/>
        </Style>
        <Style TargetType="ComboBox" BasedOn="{StaticResource MahApps.Styles.ComboBox}">
            <Setter Property="Validation.ErrorTemplate" Value="{StaticResource BottomErrorTemplate}"/>
        </Style>
    </mah:MetroWindow.Resources>

    <Grid>
        <Grid IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ШАПКА ДОКУМЕНТА (Фиксированная) -->
            <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="20,15" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,30,0">
                        <TextBlock Text="Дата заказа:" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <DatePicker SelectedDate="{Binding OrderDate}" Width="150" Height="40" IsEnabled="{Binding IsEditable}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,30,0">
                        <TextBlock Text="Контрагент (Покупатель):" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding AvailableCustomers}" 
                                  SelectedItem="{Binding SelectedCustomer, ValidatesOnDataErrors=True}" 
                                  DisplayMemberPath="Name" 
                                  mah:TextBoxHelper.Watermark="Выберите клиента..." 
                                  Height="40" IsEnabled="{Binding IsEditable}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,30,0">
                        <TextBlock Text="Склад отгрузки:" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding AvailableWarehouses}" 
                                  SelectedItem="{Binding SelectedWarehouse}" 
                                  DisplayMemberPath="Name" 
                                  mah:TextBoxHelper.Watermark="Выберите склад..." 
                                  Height="40" IsEnabled="{Binding IsEditable}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Margin="0,0,30,0" VerticalAlignment="Center">
                        <TextBlock Text="Приоритет:" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding AvailablePriorities}" 
                                  SelectedItem="{Binding SelectedPriority}" 
                                  Height="40" Width="150" IsEnabled="{Binding IsEditable}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource OrderPriorityToTextConverter}}" FontWeight="Bold"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <TextBlock Text="Статус заказа:" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold" Margin="0,0,0,5" HorizontalAlignment="Right"/>
                        <Border Background="{Binding Status, Converter={StaticResource OrderStatusToColorConverter}}" CornerRadius="4" Padding="15,8">
                            <TextBlock Text="{Binding Status, Converter={StaticResource OrderStatusToTextConverter}}" Foreground="White" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ВКЛАДКИ ДОКУМЕНТА -->
            <TabControl Grid.Row="1" Margin="10,15,10,0" mah:TabControlHelper.Underlined="TabPanel" Background="Transparent" BorderThickness="0">

                <TabItem Header="Товары и услуги" mah:HeaderedControlHelper.HeaderFontSize="15">
                    <Grid Margin="5,10,5,5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Кнопки управления табличной частью -->
                        <Grid Grid.Row="0" Margin="0,0,0,15">
                            <StackPanel Orientation="Horizontal" IsEnabled="{Binding IsEditable}">
                                <Button Content="+ ДОБАВИТЬ ТОВАР" Command="{Binding AddProductCommand}" Style="{StaticResource PrimaryButton}" Height="40" Margin="0,0,10,0"/>
                                <Button Content="УДАЛИТЬ" Command="{Binding RemoveProductCommand}" Style="{StaticResource MenuButton}" Foreground="#D32F2F" Height="40"/>
                            </StackPanel>
                        </Grid>

                        <!-- Индикатор дефицита (если есть нехватка на складе) -->
                        <Border Grid.Row="1" Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1" CornerRadius="6" Padding="15,10" Margin="0,0,0,15" Visibility="{Binding HasDeficit, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="AlertCircleOutline" Foreground="#DC2626" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="Внимание: На выбранном складе недостаточно товара для обеспечения заказа!" Foreground="#991B1B" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0"/>
                                <Button Content="СДЕЛАТЬ ЗАПРОС НА СКЛАД" Command="{Binding CreateWarehouseRequestCommand}" Style="{StaticResource PrimaryButton}" Background="#DC2626" Padding="15,5" Height="32"/>
                            </StackPanel>
                        </Border>

                        <!-- Табличная часть -->
                        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <DataGrid ItemsSource="{Binding Items}" 
                                      SelectedItem="{Binding SelectedItem}" 
                                      AutoGenerateColumns="False" 
                                      CanUserAddRows="False" 
                                      Margin="10" 
                                      IsReadOnly="{Binding IsPosted}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Артикул" Binding="{Binding Product.SKU}" IsReadOnly="True" Width="100" FontWeight="Bold"/>
                                    <DataGridTextColumn Header="Номенклатура" Binding="{Binding Product.Name}" IsReadOnly="True" Width="*"/>
                                    <DataGridTemplateColumn Header="Упаковка" Width="140">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox ItemsSource="{Binding AvailablePackagings}"
                                                          SelectedItem="{Binding SelectedPackaging, UpdateSourceTrigger=PropertyChanged}"
                                                          DisplayMemberPath="Unit.Name"
                                                          BorderThickness="0" Background="Transparent"
                                                          IsEnabled="{Binding DataContext.IsEditable, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Кол-во" Width="80">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Quantity}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsDeficit}" Value="True">
                                                                    <Setter Property="Foreground" Value="#EF4444"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="На складе" Binding="{Binding AvailableStock}" IsReadOnly="True" Width="90" Foreground="#6B7280"/>
                                    <DataGridTextColumn Header="Цена (₽)" Binding="{Binding Price, StringFormat={}{0:N2}}" IsReadOnly="True" Width="120"/>
                                    <DataGridTextColumn Header="Вес (кг)" Binding="{Binding TotalWeight, StringFormat={}{0:N3}}" IsReadOnly="True" Width="100" Foreground="#10B981" FontWeight="SemiBold"/>
                                    <DataGridTextColumn Header="Сумма" Binding="{Binding TotalPrice, StringFormat={}{0:N2}}" IsReadOnly="True" Width="130" FontWeight="Bold" Foreground="#1976D2"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <!-- Панель Итогов и редактирования количества -->
                        <Border Grid.Row="3" Background="#F8FAFC" BorderThickness="1" BorderBrush="#E2E8F0" CornerRadius="8" Padding="15" Margin="0,15,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Блок изменения количества выбранной строки -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedItem}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Hidden"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <TextBlock Text="Редактирование кол-ва:" FontSize="13" FontWeight="SemiBold" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding SelectedItem.Product.Name}" MaxWidth="220" TextTrimming="CharacterEllipsis" FontSize="14" FontWeight="Bold" Margin="0,0,15,0" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" IsEnabled="{Binding IsEditable}">
                                        <Button Command="{Binding SelectedItem.DecreaseQuantityCommand}" Content="-" Width="36" Height="36" Padding="0" Style="{StaticResource MahApps.Styles.Button.Square.Accent}" Background="White" Foreground="Black" BorderBrush="#CBD5E1" BorderThickness="1,1,0,1" FontSize="18"/>
                                        <TextBox Text="{Binding SelectedItem.Quantity, UpdateSourceTrigger=PropertyChanged}" Width="60" Height="36" TextAlignment="Center" VerticalContentAlignment="Center" FontWeight="Bold" FontSize="15" BorderBrush="#CBD5E1" BorderThickness="1"/>
                                        <Button Command="{Binding SelectedItem.IncreaseQuantityCommand}" Content="+" Width="36" Height="36" Padding="0" Style="{StaticResource MahApps.Styles.Button.Square.Accent}" Background="White" Foreground="Black" BorderBrush="#CBD5E1" BorderThickness="0,1,1,1" FontSize="18"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Блок общих итогов документа -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <StackPanel VerticalAlignment="Center" Margin="0,0,25,0">
                                        <TextBlock Text="Общий вес брутто:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                        <TextBlock Text="{Binding WeightKG, StringFormat={}{0:N2} кг}" FontWeight="Bold" FontSize="16" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    </StackPanel>

                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="ИТОГО ПО ЗАКАЗУ:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                        <TextBlock Text="{Binding TotalSum, StringFormat={}{0:N2} ₽}" FontWeight="Bold" FontSize="20" Foreground="{StaticResource PrimaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Условия поставки" mah:HeaderedControlHelper.HeaderFontSize="15">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="5,10,5,5">
                            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="25" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" VerticalAlignment="Top">
                                <StackPanel>
                                    <TextBlock Text="Дополнительные требования к транспортировке" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,25"/>

                                    <CheckBox IsChecked="{Binding RequiredTempMode}" Content="Требуется рефрижератор (ХОУ)" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,25" IsEnabled="{Binding IsEditable}"/>

                                    <TextBlock Text="Комментарий к заказу (для логиста и сборщика):" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Height="120" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" IsEnabled="{Binding IsEditable}" mah:TextBoxHelper.Watermark="Например: Позвонить за час до приезда, требуется пропуск..."/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </TabItem>
            </TabControl>

            <!-- ПОДВАЛ С КНОПКАМИ ДЕЙСТВИЙ -->
            <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="20,15">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                    <Button Content="ОТМЕНА" Command="{Binding CancelCommand}" Style="{StaticResource MenuButton}" Margin="0,0,10,0" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>

                    <Button Command="{Binding CancelOrderCommand}" Style="{StaticResource MenuButton}" Margin="0,0,10,0" Visibility="{Binding IsPosted, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Cancel" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="#D32F2F"/>
                            <TextBlock Text="ОТМЕНИТЬ ЗАКАЗ" VerticalAlignment="Center" FontWeight="Bold" Foreground="#D32F2F"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding SaveDraftCommand}" Style="{StaticResource MenuButton}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,10,0" Visibility="{Binding IsEditable, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="ContentSaveOutline" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="СОХРАНИТЬ ЧЕРНОВИК" VerticalAlignment="Center" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding UnpostCommand}" Style="{StaticResource MenuButton}" Margin="0,0,10,0" Visibility="{Binding IsPosted, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="FileUndoOutline" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="#F59E0B"/>
                            <TextBlock Text="ОТМЕНИТЬ ПРОВЕДЕНИЕ" VerticalAlignment="Center" FontWeight="Bold" Foreground="#F59E0B"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding PostCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,0,0" Visibility="{Binding IsEditable, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal" Margin="5,0">
                            <iconPacks:PackIconMaterial Kind="CheckAll" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="ПРОВЕСТИ ДОКУМЕНТ" VerticalAlignment="Center" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>

                </StackPanel>
            </Border>
        </Grid>

        <!-- ПЛАВНАЯ АНИМАЦИЯ ОВЕРЛЕЯ ЗАГРУЗКИ -->
        <Border Background="#99FFFFFF" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="999">
            <mah:ProgressRing IsActive="True" Foreground="{StaticResource PrimaryBrush}" Width="60" Height="60"/>
        </Border>
    </Grid>
</mah:MetroWindow>