<mah:MetroWindow x:Class="LogisticsApp.Views.Windows.NomenclaturePickerWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                 xmlns:local="clr-namespace:LogisticsApp.Views.Windows"
                 Title="Подбор номенклатуры"
                 Height="700" Width="1000"
                 WindowStartupLocation="CenterScreen"
                 Background="{StaticResource BackgroundBrush}"
                 GlowBrush="{StaticResource PrimaryBrush}"
                 BorderThickness="1">

    <mah:MetroWindow.Resources>
        <local:NomenclatureInverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <local:NumericGreaterThanZeroConverter x:Key="NumericGreaterThanZeroConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </mah:MetroWindow.Resources>

    <Grid>
        <Grid IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="20,15" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                        <TextBlock Text="Поиск товара:" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                 mah:TextBoxHelper.Watermark="Поиск по артикулу, штрихкоду или наименованию..." 
                                 mah:TextBoxHelper.ClearTextButton="True"
                                 Height="40" FontSize="14">
                            <mah:TextBoxHelper.ButtonContent>
                                <iconPacks:PackIconMaterial Kind="Magnify" Width="16" Height="16"/>
                            </mah:TextBoxHelper.ButtonContent>
                        </TextBox>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,20,0">
                        <TextBlock Text="Группа (Категория):" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding AvailableProductGroups}" 
                                  SelectedItem="{Binding SelectedProductGroup}" 
                                  DisplayMemberPath="Name" 
                                  mah:TextBoxHelper.Watermark="Все товарные группы" 
                                  mah:TextBoxHelper.ClearTextButton="True"
                                  Height="40" FontSize="14"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" VerticalAlignment="Bottom" Height="40" HorizontalAlignment="Center">
                        <CheckBox IsChecked="{Binding OnlyInStock}" Content="Только в наличии" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Margin="20,20,20,10" Background="{StaticResource SurfaceBrush}" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <DataGrid ItemsSource="{Binding FilteredProducts}" 
                          SelectedItem="{Binding SelectedProduct}" 
                          AutoGenerateColumns="False" 
                          CanUserAddRows="False" 
                          IsReadOnly="True"
                          Margin="10"
                          RowHeight="40">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Артикул" Binding="{Binding SKU}" Width="120" FontWeight="Bold"/>
                        <DataGridTextColumn Header="Наименование номенклатуры" Binding="{Binding Name}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextWrapping" Value="NoWrap"/>
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Группа" Binding="{Binding ProductGroup.Name}" Width="180" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <DataGridTextColumn Header="Базовая цена" Binding="{Binding BasePrice, StringFormat={}{0:N2} ₽}" Width="120"/>
                        <DataGridTextColumn Header="Свободный остаток" Binding="{Binding AvailableStock, StringFormat={}{0:N2}}" Width="140" FontWeight="Bold">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AvailableStock}" Value="0">
                                            <Setter Property="Foreground" Value="#DC2626"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding AvailableStock, Converter={StaticResource NumericGreaterThanZeroConverter}}" Value="True">
                                            <Setter Property="Foreground" Value="#10B981"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Ед. изм." Binding="{Binding BaseUnit.Name}" Width="80" Foreground="{StaticResource TextSecondaryBrush}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="20,15">
                <Grid>
                    <Border Background="#F8FAFC" BorderThickness="1" BorderBrush="#E2E8F0" CornerRadius="8" Padding="15" Margin="0,0,320,0" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedProduct}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Hidden"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <iconPacks:PackIconMaterial Kind="PackageVariantClosed" Foreground="{StaticResource PrimaryBrush}" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,15,0"/>

                            <StackPanel VerticalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="Выбранный товар:" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding SelectedProduct.Name}" FontWeight="Bold" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="ОТМЕНА" Command="{Binding CancelCommand}" Style="{StaticResource MenuButton}" Margin="0,0,15,0" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>

                        <Button Command="{Binding ConfirmCommand}" Style="{StaticResource PrimaryButton}" Height="46" Padding="25,0">
                            <StackPanel Orientation="Horizontal" Margin="5,0">
                                <iconPacks:PackIconMaterial Kind="PlusThick" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="ВЫБРАТЬ И ДОБАВИТЬ" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Background="#99FFFFFF" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="999">
            <mah:ProgressRing IsActive="True" Foreground="{StaticResource PrimaryBrush}" Width="60" Height="60"/>
        </Border>
    </Grid>
</mah:MetroWindow>