<UserControl x:Class="LogisticsApp.Views.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             Background="#F8F9FC">

    <Grid>
        <!-- Фоновые декоративные элементы -->
        <Ellipse Width="600" Height="600" Fill="{StaticResource PrimaryLightBrush}" Opacity="0.2" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-200,-200,0"/>
        <Ellipse Width="400" Height="400" Fill="{StaticResource PrimaryLightBrush}" Opacity="0.1" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-100,0,0,-100"/>

        <!-- Центральный контент -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

            <!-- Логотип -->
            <Border Background="White" Width="820" Height="232" CornerRadius="30" HorizontalAlignment="Center" Margin="0,0,0,30">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="10" Opacity="0.08"/>
                </Border.Effect>
                <Image Source="/Assets/logo.jpg" Margin="1,10,20,10"/>

            </Border>

            <!-- Текстовая информация -->
            <TextBlock Text="ООО ТД БРЯНСКИЙ МЯСОКОМБИНАТ" 
                       FontSize="36" 
                       FontWeight="Bold" 
                       Foreground="#111827" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,10"/>

            <TextBlock Text="АВТОМАТИЗИРОВАННАЯ ИНФОРМАЦИОННАЯ СИСТЕМА&#10;ОРГАНИЗАЦИИ ЛОГИСТИКИ КООПЕРАТИВНОГО ТРАНСПОРТА" 
                       FontSize="18" 
                       FontWeight="SemiBold" 
                       Foreground="{StaticResource PrimaryBrush}" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,30" Height="50" Width="698" TextAlignment="Center"/>

            <TextBlock Text="Добро пожаловать в единую среду управления кооперативным транспортом.&#x0a;Используйте боковое меню для навигации по разделам системы." 
                       FontSize="15" 
                       Foreground="#6B7280" 
                       TextAlignment="Center" 
                       LineHeight="24"
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,50"/>

            <!-- Бейджи с версией и статусом -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Border Background="#E0E7FF" CornerRadius="8" Padding="15,8" Margin="0,0,15,0">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Information" Foreground="#3B82F6" VerticalAlignment="Center" Margin="0,0,8,0" Width="14" Height="14"/>
                        <TextBlock Text="Версия 2.0 Enterprise" Foreground="#1D4ED8" FontWeight="Bold" FontSize="13"/>
                    </StackPanel>
                </Border>
                <Border Background="#DCFCE7" CornerRadius="8" Padding="15,8">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="CheckCircle" Foreground="#10B981" VerticalAlignment="Center" Margin="0,0,8,0" Width="14" Height="14"/>
                        <TextBlock Text="Система работает стабильно" Foreground="#047857" FontWeight="Bold" FontSize="13"/>
                    </StackPanel>
                </Border>
            </StackPanel>

        </StackPanel>

        <TextBlock Text="ООО ТД Брянский Мясокомбинат" 
                   Foreground="#9CA3AF" 
                   FontSize="12" 
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Bottom" 
                   Margin="0,0,0,20"/>
    </Grid>
</UserControl>