<mah:MetroWindow x:Class="LogisticsApp.Views.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                 xmlns:vm="clr-namespace:LogisticsApp.ViewModels"
                 xmlns:views="clr-namespace:LogisticsApp.Views"
                 mc:Ignorable="d"
                 Title="Logistics ERP Enterprise" 
                 Height="850" Width="1400"
                 WindowStartupLocation="CenterScreen"
                 GlowBrush="{StaticResource PrimaryBrush}">

    <mah:MetroWindow.RightWindowCommands>
        <mah:WindowCommands>
            <Button Command="{Binding ShowHelpCommand}" ToolTip="Справочная информация по текущему модулю" Cursor="Hand" Padding="10,0">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="HelpCircleOutline" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="СПРАВКА" VerticalAlignment="Center" FontWeight="Bold" FontSize="13"/>
                </StackPanel>
            </Button>
        </mah:WindowCommands>
    </mah:MetroWindow.RightWindowCommands>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <DataTemplate DataType="{x:Type vm:HomeViewModel}">
            <views:HomePage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:OrdersViewModel}">
            <views:OrdersPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:WaybillsViewModel}">
            <views:WaybillsPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:InventoryViewModel}">
            <views:InventoryPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FinanceViewModel}">
            <views:FinancePage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:VehiclesViewModel}">
            <views:VehiclesPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DriversViewModel}">
            <views:DriversPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CustomersViewModel}">
            <views:CustomersPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:NomenclatureViewModel}">
            <views:NomenclaturePage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportsViewModel}">
            <views:ReportsPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LogViewerViewModel}">
            <views:LogViewerPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:UsersViewModel}">
            <views:UsersPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RolesViewModel}">
            <views:RolesPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AuditViewModel}">
            <views:AuditPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ArchiveViewModel}">
            <views:ArchivePage />
        </DataTemplate>

        <Style x:Key="MenuButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryLightBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="Margin" Value="12,2,12,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="GroupName" Value="MainMenu"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid Background="Transparent">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8"/>
                            <Border x:Name="AccentBd" Width="4" HorizontalAlignment="Left" CornerRadius="2" Background="Transparent" Margin="0,10,0,10"/>
                            <ContentPresenter VerticalAlignment="Center" Margin="20,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource PrimaryDarkBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource PrimaryDarkBrush}"/>
                                <Setter TargetName="AccentBd" Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="270"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource PrimaryBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="20,30,20,15">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,30">
                        <Border Background="White" Width="38" Height="38" CornerRadius="8">
                            <Image Source="/Assets/logo.png" Margin="5" RenderOptions.BitmapScalingMode="HighQuality">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Style.Triggers>
                                            <Trigger Property="Source" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                        </Border>
                        <TextBlock Text="ТД БРЯНСКИЙ&#x0a;МЯСОКОМБИНАТ" Foreground="White" FontSize="14" FontWeight="Bold" Margin="15,0,0,0" VerticalAlignment="Center" LineHeight="16"/>
                    </StackPanel>

                    <Border Background="{StaticResource PrimaryDarkBrush}" CornerRadius="10" Padding="15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <iconPacks:PackIconMaterial Kind="AccountCircle" Foreground="{StaticResource PrimaryLightBrush}" Width="32" Height="32" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding UserName}" Foreground="White" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding UserRole}" Foreground="{StaticResource PrimaryLightBrush}" FontSize="11"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>

                <Grid Grid.Row="1">
                    <ScrollViewer x:Name="MenuScrollViewer" VerticalScrollBarVisibility="Hidden" Margin="0,0,0,0">
                        <StackPanel Margin="0,0,0,60">
                            <RadioButton Style="{StaticResource MenuButtonStyle}" Command="{Binding NavigateHomeCommand}" IsChecked="True">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Home" Width="18" Height="18" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Главная" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>

                            <StackPanel Visibility="{Binding CanViewOrdersOrWaybills, Converter={StaticResource BoolToVis}}">
                                <Grid Margin="20,15,20,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="ОПЕРАЦИИ" Foreground="{StaticResource PrimaryLightBrush}" Opacity="0.7" FontSize="11" FontWeight="Bold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" Height="1" Background="{StaticResource PrimaryLightBrush}" Opacity="0.2" VerticalAlignment="Center"/>
                                </Grid>
                                <RadioButton Style="{StaticResource MenuButtonStyle}" Command="{Binding NavigateOrdersCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="ClipboardListOutline" Width="18" Height="18" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Заказы покупателей" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </RadioButton>
                                <RadioButton Style="{StaticResource MenuButtonStyle}" Command="{Binding NavigateWaybillsCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="MapMarkerPath" Width="18" Height="18" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Путевые листы" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </RadioButton>
                            </StackPanel>

                            <StackPanel Visibility="{Binding CanViewInventory, Converter={StaticResource BoolToVis}}">
                                <Grid Margin="20,15,20,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="СКЛАД И ЗАПАСЫ" Foreground="{StaticResource PrimaryLightBrush}" Opacity="0.7" FontSize="11" FontWeight="Bold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" Height="1" Background="{StaticResource PrimaryLightBrush}" Opacity="0.2" VerticalAlignment="Center"/>
                                </Grid>
                                <RadioButton Style="{StaticResource MenuButtonStyle}" Command="{Binding NavigateInventoryCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Warehouse" Width="18" Height="18" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Управление остатками" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </RadioButton>
                            </StackPanel>

                            <StackPanel Visibility="{Binding CanViewFinance, Converter={StaticResource BoolToVis}}">
                                <Grid Margin="20,15,20,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="ФИНАНСЫ И КАЗНАЧЕЙСТВО" Foreground="{StaticResource PrimaryLightBrush}" Opacity="0.7" FontSize="11" FontWeight="Bold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" Height="1" Background="{StaticResource PrimaryLightBrush}" Opacity="0.2" VerticalAlignment="Center"/>
                                </Grid>
                                <RadioButton Style="{StaticResource MenuButtonStyle}" Command="{Binding NavigateFinanceCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="CashRegister" Width="18" Height="18" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Взаиморасчеты" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </RadioButton>
                            </StackPanel>

                            <StackPanel Visibility="{Binding CanViewDictionaries, Converter={StaticResource BoolToVis}}">
                                <Grid Margin="20,15,20,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="БАЗА И СПРАВОЧНИКИ" Foreground="{StaticResource PrimaryLightBrush}" Opacity="0.7" FontSize="11" FontWeight="Bold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" Height="1" Background="{StaticResource PrimaryLightBrush}" Opacity="0.2" VerticalAlignment="Center"/>
                                </Grid>
                                <RadioButton Style="{StaticResource MenuButtonStyle}" Command="{Binding NavigateNomenclatureCommand}" Visibility="{Binding CanViewNomenclature, Converter={StaticResource BoolToVis}}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="PackageVariant" Width="18" Height="18" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Номенклатура" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </RadioButton>
                                <RadioButton Style="{StaticResource MenuButtonStyle}" Command="{Binding NavigateCustomersCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="StorefrontOutline" Width="18" Height="18" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Контрагенты" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </RadioButton>
                                <RadioButton Style="{StaticResource MenuButtonStyle}" Command="{Binding NavigateVehiclesCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="TruckOutline" Width="18" Height="18" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Автопарк" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </RadioButton>
                                <RadioButton Style="{StaticResource MenuButtonStyle}" Command="{Binding NavigateDriversCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="CardAccountDetailsOutline" Width="18" Height="18" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Сотрудники (Водители)" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </RadioButton>
                            </StackPanel>

                            <StackPanel Visibility="{Binding CanViewReports, Converter={StaticResource BoolToVis}}">
                                <Grid Margin="20,15,20,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="АНАЛИТИКА" Foreground="{StaticResource PrimaryLightBrush}" Opacity="0.7" FontSize="11" FontWeight="Bold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" Height="1" Background="{StaticResource PrimaryLightBrush}" Opacity="0.2" VerticalAlignment="Center"/>
                                </Grid>
                                <RadioButton Style="{StaticResource MenuButtonStyle}" Command="{Binding NavigateReportsCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="ChartBar" Width="18" Height="18" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Отчеты и Выгрузки" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </RadioButton>
                            </StackPanel>

                            <StackPanel Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}">
                                <Grid Margin="20,15,20,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="АДМИНИСТРИРОВАНИЕ" Foreground="{StaticResource PrimaryLightBrush}" Opacity="0.7" FontSize="11" FontWeight="Bold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" Height="1" Background="{StaticResource PrimaryLightBrush}" Opacity="0.2" VerticalAlignment="Center"/>
                                </Grid>
                                <RadioButton Style="{StaticResource MenuButtonStyle}" Command="{Binding NavigateUsersCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="AccountGroup" Width="18" Height="18" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Пользователи" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </RadioButton>
                                <RadioButton Style="{StaticResource MenuButtonStyle}" Command="{Binding NavigateRolesCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Security" Width="18" Height="18" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Управление ролями" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </RadioButton>
                                <RadioButton Style="{StaticResource MenuButtonStyle}" Command="{Binding NavigateAuditCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="History" Width="18" Height="18" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Аудит БД" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </RadioButton>
                                <RadioButton Style="{StaticResource MenuButtonStyle}" Command="{Binding NavigateArchiveCommand}" Visibility="{Binding CanAccessSettings, Converter={StaticResource BoolToVis}}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="DeleteRestore" Width="18" Height="18" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Корзина (Архив)" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </RadioButton>
                                <RadioButton Style="{StaticResource MenuButtonStyle}" Command="{Binding NavigateSettingsCommand}" Visibility="{Binding CanAccessSettings, Converter={StaticResource BoolToVis}}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Cog" Width="18" Height="18" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Настройки системы" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </RadioButton>
                                <RadioButton Style="{StaticResource MenuButtonStyle}" Command="{Binding NavigateLogsCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Console" Width="18" Height="18" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Системный журнал" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </RadioButton>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>

                    <Border VerticalAlignment="Bottom" Height="80">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#00D32F2F" Offset="0"/>
                                <GradientStop Color="#E6D32F2F" Offset="0.8"/>
                                <GradientStop Color="#FFD32F2F" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Button Command="ScrollBar.ScrollToEndCommand" CommandTarget="{Binding ElementName=MenuScrollViewer}" Cursor="Hand" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,15" Background="Transparent" BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}">
                                        <ContentPresenter/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel>
                                <iconPacks:PackIconMaterial Kind="ChevronDoubleDown" Foreground="{StaticResource PrimaryLightBrush}" Opacity="0.8" Width="18" Height="18" HorizontalAlignment="Center">
                                    <iconPacks:PackIconMaterial.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                                                        From="0,0,0,0" To="0,4,0,-4"
                                                                        Duration="0:0:0.7" AutoReverse="True"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </iconPacks:PackIconMaterial.Triggers>
                                </iconPacks:PackIconMaterial>
                                <TextBlock Text="Листайте вниз" Foreground="{StaticResource PrimaryLightBrush}" Opacity="0.7" FontSize="10" FontWeight="SemiBold" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Border>
                </Grid>

                <Button Grid.Row="2" Click="BtnLogout_Click" Background="Transparent" BorderThickness="0" Margin="0,15,0,25" Cursor="Hand" ToolTip="Сменить пользователя">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Logout" Foreground="White" Opacity="0.8" Width="18" Height="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Выйти из системы" Foreground="White" Opacity="0.8" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <ContentControl Grid.Column="1" Content="{Binding CurrentView}"/>

        <Grid x:Name="OverlayGrid" Grid.ColumnSpan="2" Background="#80000000" Visibility="Collapsed" Panel.ZIndex="999">
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="35" HorizontalAlignment="Center" VerticalAlignment="Center" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <StackPanel>
                    <mah:ProgressRing IsActive="True" Foreground="{StaticResource PrimaryBrush}" Width="50" Height="50" Margin="0,0,0,20"/>
                    <TextBlock x:Name="OverlayText" Text="Пожалуйста, подождите..." FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</mah:MetroWindow>