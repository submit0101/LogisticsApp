<UserControl x:Class="LogisticsApp.Views.UsersPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1100">
    <b:Interaction.Triggers>
        <b:EventTrigger EventName="Loaded">
            <b:InvokeCommandAction Command="{Binding LoadUsersCommand}" />
        </b:EventTrigger>
    </b:Interaction.Triggers>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="20" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Column="0" Margin="0,0,25,0" VerticalAlignment="Center">
                    <Border Width="40" Height="40" Background="{StaticResource PrimaryLightBrush}" CornerRadius="8">
                        <iconPacks:PackIconMaterial Kind="AccountGroup" Foreground="{StaticResource PrimaryDarkBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" Width="20" Height="20"/>
                    </Border>
                    <StackPanel Margin="15,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Управление доступом" FontWeight="Bold" FontSize="16" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Список системных пользователей" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="УДАЛИТЬ" Command="{Binding DeleteUserCommand}" Style="{StaticResource MenuButton}" Foreground="#D32F2F" Margin="0,0,10,0"/>
                    <Button Content="РЕДАКТИРОВАТЬ" Command="{Binding EditUserCommand}" Style="{StaticResource MenuButton}" Margin="0,0,10,0"/>
                    <Button Content="+ СОЗДАТЬ ПОЛЬЗОВАТЕЛЯ" Command="{Binding AddUserCommand}" Style="{StaticResource PrimaryButton}"/>
                </StackPanel>
            </Grid>
        </Border>
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" CornerRadius="8" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}" Margin="0,15,0,0">
            <DataGrid ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser}" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" Margin="15">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding UserID}" Width="60" FontWeight="Bold"/>
                    <DataGridTemplateColumn Header="Сотрудник" Width="300">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="AccountCircle" Width="18" Height="18" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="{DynamicResource MahApps.Brushes.Accent}"/>
                                    <TextBlock Text="{Binding FullName}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="200"/>

                    <!-- ИСПРАВЛЕНИЕ: Выводим именно имя роли, а не сам объект -->
                    <DataGridTextColumn Header="Роль" Binding="{Binding Role.Name}" Width="200" FontWeight="Bold" Foreground="#1976D2"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>