<UserControl x:Class="LogisticsApp.Views.NomenclaturePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:core="clr-namespace:LogisticsApp.Core"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1200">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <core:PermissionToVisibilityConverter x:Key="PermissionToVisibility"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="20" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Column="0" Margin="0,0,25,0" VerticalAlignment="Center">
                    <Border Width="40" Height="40" Background="{StaticResource PrimaryLightBrush}" CornerRadius="8">
                        <iconPacks:PackIconMaterial Kind="PackageVariant" Foreground="{StaticResource PrimaryDarkBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" Width="20" Height="20"/>
                    </Border>
                    <StackPanel Margin="15,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Номенклатура" FontWeight="Bold" FontSize="16" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Справочник ТМЦ и Цены" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>
                <TextBox Grid.Column="1" Style="{StaticResource ModernTextBox}"
                         mah:TextBoxHelper.Watermark="Интеллектуальный поиск (Код, Наименование)..."
                         mah:TextBoxHelper.ClearTextButton="True"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=500}"
                         Margin="0,0,15,0" Height="40" VerticalContentAlignment="Center"/>
                <Button Grid.Column="2" Command="{Binding LoadDataCommand}" Style="{StaticResource MenuButton}" ToolTip="Обновить таблицу" Height="40" Padding="15,0">
                    <iconPacks:PackIconMaterial Kind="Refresh" Width="16" Height="16" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}" CornerRadius="8">
                <TreeView ItemsSource="{Binding GroupNodes}" BorderThickness="0" Background="Transparent" Margin="10">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                            <Setter Property="Padding" Value="4,4"/>
                            <Setter Property="Margin" Value="0,2"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <iconPacks:PackIconMaterial x:Name="Icon" Kind="Folder" Foreground="#EAB308" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            </StackPanel>
                            <HierarchicalDataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                    <Setter TargetName="Icon" Property="Kind" Value="FolderOpen"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsRoot}" Value="True">
                                    <Setter TargetName="Icon" Property="Kind" Value="Database"/>
                                    <Setter TargetName="Icon" Property="Foreground" Value="#3B82F6"/>
                                </DataTrigger>
                            </HierarchicalDataTemplate.Triggers>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="Transparent" Cursor="SizeWE"/>

            <Border Grid.Column="2" Background="{StaticResource SurfaceBrush}" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}" CornerRadius="8">
                <DataGrid ItemsSource="{Binding Products}" 
                          SelectedItem="{Binding SelectedProduct}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          Margin="10"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          ScrollViewer.CanContentScroll="True">
                    <DataGrid.InputBindings>
                        <MouseBinding Gesture="LeftDoubleClick" Command="{Binding EditProductCommand}"/>
                    </DataGrid.InputBindings>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Артикул" Binding="{Binding SKU}" Width="120" FontWeight="Bold"/>
                        <DataGridTemplateColumn Header="Наименование" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock core:TextBlockHighlighter.Text="{Binding Name}"
                                               core:TextBlockHighlighter.Selection="{Binding DataContext.SearchText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Текущая цена (₽)" Binding="{Binding CurrentPrice, StringFormat={}{0:N2}}" Width="140" FontWeight="Bold" Foreground="#10B981"/>
                        <DataGridTextColumn Header="Штрихкод" Binding="{Binding Barcode}" Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" Padding="20" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Content="ИМПОРТ ИЗ EXCEL" 
                            Command="{Binding ImportCommand}" 
                            Visibility="{Binding Converter={StaticResource PermissionToVisibility}, ConverterParameter=EditNomenclature}"
                            Style="{StaticResource MenuButton}" 
                            Foreground="#2E7D32"
                            Margin="0,0,10,0"/>
                    <Button Content="ЭКСПОРТ В EXCEL" 
                            Command="{Binding ExportCommand}" 
                            Visibility="{Binding Converter={StaticResource PermissionToVisibility}, ConverterParameter=ViewNomenclature}"
                            Style="{StaticResource MenuButton}" 
                            Foreground="#1565C0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Command="{Binding DeleteProductCommand}" 
                            Visibility="{Binding Converter={StaticResource PermissionToVisibility}, ConverterParameter=DeleteNomenclature}"
                            Style="{StaticResource MenuButton}" 
                            Foreground="#D32F2F" 
                            Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="CloseBoxOutline" Foreground="#D32F2F" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="ПОМЕТИТЬ НА УДАЛЕНИЕ" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Content="РЕДАКТИРОВАТЬ" 
                            Command="{Binding EditProductCommand}" 
                            Visibility="{Binding Converter={StaticResource PermissionToVisibility}, ConverterParameter=EditNomenclature}"
                            Style="{StaticResource MenuButton}" 
                            Margin="0,0,10,0"/>
                    <Button Content="+ ДОБАВИТЬ ТОВАР" 
                            Command="{Binding AddProductCommand}" 
                            Visibility="{Binding Converter={StaticResource PermissionToVisibility}, ConverterParameter=EditNomenclature}"
                            Style="{StaticResource PrimaryButton}"/>
                </StackPanel>
            </Grid>
        </Border>

        <ProgressBar Grid.Row="1" IsIndeterminate="True" VerticalAlignment="Top" Height="4" BorderThickness="0" Margin="20,0,20,0"
                     Foreground="{StaticResource PrimaryBrush}" Background="Transparent"
                     Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
    </Grid>
</UserControl>