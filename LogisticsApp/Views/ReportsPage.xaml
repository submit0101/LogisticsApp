<UserControl x:Class="LogisticsApp.Views.ReportsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             xmlns:local="clr-namespace:LogisticsApp.Views"
             mc:Ignorable="d" 
             d:DesignHeight="850" d:DesignWidth="1300"
             Background="#F8F9FC">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:ReportsInverseBooleanToVisibilityConverter x:Key="InverseBoolToVis"/>

        <GroupStyle x:Key="OneCGroupStyle">
            <GroupStyle.ContainerStyle>
                <Style TargetType="{x:Type GroupItem}">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type GroupItem}">
                                <Expander IsExpanded="True" Background="#F1F5F9" BorderBrush="#CBD5E1" BorderThickness="1,1,1,2" Margin="0,4,0,2">
                                    <Expander.Header>
                                        <StackPanel Orientation="Horizontal" Margin="5,8">
                                            <iconPacks:PackIconMaterial Kind="FolderOpen" Foreground="#3B82F6" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#1E293B" FontSize="14" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding ItemCount, StringFormat=' (Документов/Строк: {0})'}" Foreground="#64748B" Margin="10,0,0,0" VerticalAlignment="Center" FontStyle="Italic"/>
                                        </StackPanel>
                                    </Expander.Header>
                                    <Border Background="White" BorderThickness="0,1,0,0" BorderBrush="#E2E8F0">
                                        <ItemsPresenter />
                                    </Border>
                                </Expander>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </GroupStyle.ContainerStyle>
        </GroupStyle>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="25" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="4" Opacity="0.04"/>
            </Border.Effect>
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,30">
                    <Border Width="45" Height="45" Background="{StaticResource PrimaryLightBrush}" CornerRadius="12">
                        <iconPacks:PackIconMaterial Kind="ChartLine" Foreground="{StaticResource PrimaryDarkBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" Width="24" Height="24"/>
                    </Border>
                    <StackPanel Margin="15,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Конструктор" FontWeight="Bold" FontSize="18" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Аналитика и Отчеты" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>

                <TextBlock Text="Вид аналитики:" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                <ComboBox ItemsSource="{Binding ReportTypes}" SelectedItem="{Binding SelectedReportType}" Style="{StaticResource MahApps.Styles.ComboBox}" Height="42" Margin="0,0,0,25" FontSize="13"/>

                <TextBlock Text="Период формирования:" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                <StackPanel Margin="0,0,0,30">
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="С:" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <DatePicker Grid.Column="1" SelectedDate="{Binding DateFrom}" Height="40"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="По:" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <DatePicker Grid.Column="1" SelectedDate="{Binding DateTo}" Height="40"/>
                    </Grid>
                </StackPanel>

                <Button Command="{Binding GenerateReportCommand}" Style="{StaticResource PrimaryButton}" Height="48" Margin="0,0,0,15" Cursor="Hand" Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Flash" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="СФОРМИРОВАТЬ ОТЧЕТ" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding ExportReportCommand}" Style="{StaticResource MenuButton}" Height="48" Margin="0,0,0,15" Cursor="Hand" Foreground="#10B981" BorderBrush="#10B981" BorderThickness="1" Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="FileExcelBox" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="ЭКСПОРТ ТАБЛИЦЫ В EXCEL" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding CancelGenerationCommand}" Style="{StaticResource MenuButton}" Height="48" Foreground="#DC2626" BorderBrush="#DC2626" BorderThickness="1" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="StopCircleOutline" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="ОТМЕНИТЬ ОПЕРАЦИЮ" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <Border Grid.Column="2" Background="{StaticResource SurfaceBrush}" CornerRadius="12" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="4" Opacity="0.04"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TabControl mah:TabControlHelper.Underlined="TabPanel" Background="Transparent" BorderThickness="0" Margin="15,15,15,0">
                    <TabItem Header="Табличный документ" mah:HeaderedControlHelper.HeaderFontSize="15">
                        <Grid Margin="0,15,0,0">

                            <!-- 1. Реестр путевых листов -->
                            <DataGrid ItemsSource="{Binding CurrentReportView}" Visibility="{Binding IsWaybillsGridVisible, Converter={StaticResource BoolToVis}}"
                                      AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" SelectionMode="Single"
                                      VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
                                      BorderThickness="0" Background="Transparent">
                                <DataGrid.GroupStyle>
                                    <StaticResource ResourceKey="OneCGroupStyle"/>
                                </DataGrid.GroupStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="№ П/Л" Binding="{Binding WaybillID}" Width="80" FontWeight="Bold"/>
                                    <DataGridTextColumn Header="Дата" Binding="{Binding DateCreate, StringFormat=dd.MM.yyyy HH:mm}" Width="130"/>
                                    <DataGridTextColumn Header="Транспорт" Binding="{Binding VehicleReg}" Width="150" Foreground="#1976D2" FontWeight="SemiBold"/>
                                    <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="120"/>
                                    <DataGridTextColumn Header="Точек" Binding="{Binding PointsCount}" Width="80"/>
                                    <DataGridTextColumn Header="Дистанция" Binding="{Binding Distance, StringFormat={}{0:N1} км}" Width="110"/>
                                    <DataGridTextColumn Header="Вес груза" Binding="{Binding TotalWeight, StringFormat={}{0:N0} кг}" Width="110" FontWeight="Bold"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- 2. Тонно-километры -->
                            <DataGrid ItemsSource="{Binding CurrentReportView}" Visibility="{Binding IsTonKmGridVisible, Converter={StaticResource BoolToVis}}"
                                      AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" SelectionMode="Single"
                                      VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
                                      BorderThickness="0" Background="Transparent">
                                <DataGrid.GroupStyle>
                                    <StaticResource ResourceKey="OneCGroupStyle"/>
                                </DataGrid.GroupStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Даты рейса" Binding="{Binding DateOut, StringFormat=dd.MM.yyyy}" Width="150" FontWeight="SemiBold"/>
                                    <DataGridTextColumn Header="Водитель" Binding="{Binding DriverName}" Width="200" Foreground="#1976D2"/>
                                    <DataGridTextColumn Header="Пробег (км)" Binding="{Binding TotalMileage, StringFormat={}{0:N1}}" Width="100"/>
                                    <DataGridTextColumn Header="С грузом (км)" Binding="{Binding LoadedMileage, StringFormat={}{0:N1}}" Width="120"/>
                                    <DataGridTextColumn Header="Вес груза (т)" Binding="{Binding TotalWeightTons, StringFormat={}{0:N3}}" Width="110"/>
                                    <DataGridTextColumn Header="Тн*км" Binding="{Binding TonKilometers, StringFormat={}{0:N2}}" Width="110" FontWeight="Bold" Foreground="#10B981"/>
                                    <DataGridTextColumn Header="Часы" Binding="{Binding WorkHours, StringFormat={}{0:N1}}" Width="80"/>
                                    <DataGridTextColumn Header="ГСМ (л)" Binding="{Binding FuelRefueled, StringFormat={}{0:N1}}" Width="100"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- 3. Пробег автомобилей -->
                            <DataGrid ItemsSource="{Binding CurrentReportView}" Visibility="{Binding IsMileageGridVisible, Converter={StaticResource BoolToVis}}"
                                      AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" SelectionMode="Single"
                                      VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
                                      BorderThickness="0" Background="Transparent">
                                <DataGrid.GroupStyle>
                                    <StaticResource ResourceKey="OneCGroupStyle"/>
                                </DataGrid.GroupStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Гос. номер" Binding="{Binding VehicleRegNumber}" Width="180" FontWeight="Bold" Foreground="#1976D2"/>
                                    <DataGridTextColumn Header="Пробег за период (км)" Binding="{Binding PeriodMileage, StringFormat={}{0:N1}}" Width="200" FontWeight="Bold"/>
                                    <DataGridTextColumn Header="Пробег с начала экспл. (км)" Binding="{Binding TotalMileageSinceStart, StringFormat={}{0:N1}}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- 4. Показания одометров -->
                            <DataGrid ItemsSource="{Binding CurrentReportView}" Visibility="{Binding IsOdometerGridVisible, Converter={StaticResource BoolToVis}}"
                                      AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" SelectionMode="Single"
                                      VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
                                      BorderThickness="0" Background="Transparent">
                                <DataGrid.GroupStyle>
                                    <StaticResource ResourceKey="OneCGroupStyle"/>
                                </DataGrid.GroupStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Гос. номер" Binding="{Binding VehicleRegNumber}" Width="150" FontWeight="Bold" Foreground="#1976D2"/>
                                    <DataGridTextColumn Header="Одометр (Начало)" Binding="{Binding OdometerStart, StringFormat={}{0:N0}}" Width="160"/>
                                    <DataGridTextColumn Header="Пробег за период" Binding="{Binding PeriodMileage, StringFormat={}{0:N1}}" Width="160" FontWeight="Bold"/>
                                    <DataGridTextColumn Header="Одометр (Конец)" Binding="{Binding OdometerEnd, StringFormat={}{0:N0}}" Width="160"/>
                                    <DataGridTextColumn Header="Общий пробег" Binding="{Binding TotalMileageSinceStart, StringFormat={}{0:N1}}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>

                        </Grid>
                    </TabItem>

                    <TabItem Header="Графики и Аналитика" mah:HeaderedControlHelper.HeaderFontSize="15">
                        <Grid Margin="0,20,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#F8FAFC" CornerRadius="8" Padding="15" Margin="0,0,0,10" BorderBrush="#E2E8F0" BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Количественные показатели (ТОП)" FontWeight="Bold" Foreground="#334155" Margin="0,0,0,10"/>
                                    <lvc:CartesianChart Grid.Row="1" Series="{Binding MainChartSeries}" LegendLocation="None" Margin="10">
                                        <lvc:CartesianChart.AxisX>
                                            <lvc:Axis Labels="{Binding ChartLabels}" FontSize="11">
                                                <lvc:Axis.Separator>
                                                    <lvc:Separator Stroke="Transparent"/>
                                                </lvc:Axis.Separator>
                                            </lvc:Axis>
                                        </lvc:CartesianChart.AxisX>
                                    </lvc:CartesianChart>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1" Background="#F8FAFC" CornerRadius="8" Padding="15" Margin="0,10,0,0" BorderBrush="#E2E8F0" BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Долевое распределение (Структура)" FontWeight="Bold" Foreground="#334155" Margin="0,0,0,10"/>
                                    <lvc:PieChart Grid.Row="1" Series="{Binding PieChartSeries}" LegendLocation="Right" InnerRadius="40" Margin="10"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>
                </TabControl>

                <Border Grid.Row="1" Background="#FEF3C7" BorderThickness="0,2,0,0" BorderBrush="#F59E0B" CornerRadius="0,0,12,12" Padding="20,15">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="ОБЩИЕ ИТОГИ:" FontWeight="ExtraBold" Foreground="#B45309" FontSize="15" VerticalAlignment="Center" Margin="0,0,25,0"/>
                        <TextBlock Text="{Binding GrandTotal1}" FontWeight="Bold" Foreground="#92400E" FontSize="15" VerticalAlignment="Center" Margin="0,0,25,0"/>
                        <TextBlock Text="{Binding GrandTotal2}" FontWeight="Bold" Foreground="#92400E" FontSize="15" VerticalAlignment="Center" Margin="0,0,25,0"/>
                        <TextBlock Text="{Binding GrandTotal3}" FontWeight="Bold" Foreground="#92400E" FontSize="15" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.RowSpan="2" Background="#CCFFFFFF" CornerRadius="12" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <mah:ProgressRing IsActive="True" Foreground="{StaticResource PrimaryBrush}" Width="60" Height="60" Margin="0,0,0,15"/>
                        <TextBlock Text="Выполнение агрегации..." FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>