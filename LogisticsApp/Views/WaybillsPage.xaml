<UserControl x:Class="LogisticsApp.Views.WaybillsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:core="clr-namespace:LogisticsApp.Core"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1200">
    <b:Interaction.Triggers>
        <b:EventTrigger EventName="Loaded">
            <b:InvokeCommandAction Command="{Binding LoadDataCommand}" />
        </b:EventTrigger>
    </b:Interaction.Triggers>
    <UserControl.Resources>
        <core:WaybillStatusToColorConverter x:Key="WaybillStatusToColorConverter"/>
        <core:WaybillStatusToTextConverter x:Key="WaybillStatusToTextConverter"/>
        <core:PermissionToVisibilityConverter x:Key="PermissionToVisibility"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="20" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" Grid.Column="0" Margin="0,0,25,0" VerticalAlignment="Center">
                        <Border Width="40" Height="40" Background="{StaticResource PrimaryLightBrush}" CornerRadius="8">
                            <iconPacks:PackIconMaterial Kind="MapMarkerPath" Foreground="{StaticResource PrimaryDarkBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" Width="20" Height="20"/>
                        </Border>
                        <StackPanel Margin="15,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Путевые листы" FontWeight="Bold" FontSize="16" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Журнал выездов" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                    <TextBox Grid.Column="1" Style="{StaticResource ModernTextBox}"
                             mah:TextBoxHelper.Watermark="Умный поиск (№ Листа, Авто, Водитель)..."
                             mah:TextBoxHelper.ClearTextButton="True"
                             Text="{Binding HighlightText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,15,0" Height="40" VerticalContentAlignment="Center"/>
                    <Button Grid.Column="2" Command="{Binding LoadDataCommand}" Style="{StaticResource MenuButton}" ToolTip="Обновить из БД" Height="40" Padding="15,0">
                        <iconPacks:PackIconMaterial Kind="Refresh" Width="16" Height="16" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Button>
                </Grid>
                <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,-10">
                    <ComboBox Width="200" 
                              SelectedIndex="{Binding SelectedFilterIndex}"
                              mah:TextBoxHelper.Watermark="Статус рейса"
                              Margin="0,0,15,10" Height="38" VerticalContentAlignment="Center"
                              Style="{StaticResource MahApps.Styles.ComboBox}">
                        <ComboBoxItem Content="Все путевые листы"/>
                        <ComboBoxItem Content="В подготовке (Черновики)"/>
                        <ComboBoxItem Content="К выполнению (План)"/>
                        <ComboBoxItem Content="В рейсе (Активные)"/>
                        <ComboBoxItem Content="Завершены или Отменены"/>
                    </ComboBox>
                    <ComboBox Width="200" 
                              ItemsSource="{Binding VehiclesFilterList}" 
                              SelectedItem="{Binding SelectedVehicleFilter}" 
                              DisplayMemberPath="RegNumber"
                              mah:TextBoxHelper.Watermark="Все автомобили"
                              Margin="0,0,15,10" Height="38" VerticalContentAlignment="Center"
                              Style="{StaticResource MahApps.Styles.ComboBox}"/>
                    <ComboBox Width="200" 
                              ItemsSource="{Binding DriversFilterList}" 
                              SelectedItem="{Binding SelectedDriverFilter}" 
                              DisplayMemberPath="FullName"
                              mah:TextBoxHelper.Watermark="Все водители"
                              Margin="0,0,15,10" Height="38" VerticalContentAlignment="Center"
                              Style="{StaticResource MahApps.Styles.ComboBox}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,15,10">
                        <TextBlock Text="С:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                        <DatePicker SelectedDate="{Binding DateFromFilter}" Width="130" Height="38" mah:TextBoxHelper.Watermark="ДД.ММ.ГГГГ"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,15,10">
                        <TextBlock Text="По:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                        <DatePicker SelectedDate="{Binding DateToFilter}" Width="130" Height="38" mah:TextBoxHelper.Watermark="ДД.ММ.ГГГГ"/>
                    </StackPanel>
                </WrapPanel>
            </Grid>
        </Border>
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Waybills}"
                  SelectedItem="{Binding SelectedWaybill}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  Margin="20"
                  EnableRowVirtualization="True"
                  EnableColumnVirtualization="True"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  ScrollViewer.CanContentScroll="True">
            <DataGrid.InputBindings>
                <MouseBinding Gesture="LeftDoubleClick" Command="{Binding EditCommand}"/>
            </DataGrid.InputBindings>
            <DataGrid.Columns>
                <DataGridTextColumn Header="№ Листа" Binding="{Binding WaybillID}" Width="90" FontWeight="Bold"/>
                <DataGridTextColumn Header="Дата создания" Binding="{Binding DateCreate, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="140"/>
                <DataGridCheckBoxColumn Header="Проведен" Binding="{Binding IsPosted}" Width="80"/>
                <DataGridTemplateColumn Header="Автомобиль" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="TruckOutline" Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="#757575"/>
                                <TextBlock core:TextBlockHighlighter.Text="{Binding VehicleRegNumber}"
                                           core:TextBlockHighlighter.Selection="{Binding DataContext.HighlightText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Водитель" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="AccountCircleOutline" Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="#757575"/>
                                <TextBlock core:TextBlockHighlighter.Text="{Binding DriverFullName}"
                                           core:TextBlockHighlighter.Selection="{Binding DataContext.HighlightText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Выезд" Binding="{Binding DateOut, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="140"/>
                <DataGridTextColumn Header="Возврат" Binding="{Binding DateIn, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="140"/>
                <DataGridTemplateColumn Header="Статус" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Padding="10,5" CornerRadius="4" HorizontalAlignment="Left"
                                    Background="{Binding Status, Converter={StaticResource WaybillStatusToColorConverter}}">
                                <TextBlock Text="{Binding Status, Converter={StaticResource WaybillStatusToTextConverter}}" 
                                           Foreground="White" FontWeight="SemiBold" FontSize="11"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" Padding="20" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <WrapPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
                    <Button Command="{Binding ViewRouteCommand}" Style="{StaticResource MenuButton}" Margin="0,5,10,5" ToolTip="Маршрут на карте">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="MapSearch" Margin="0,0,8,0" Foreground="#1976D2"/>
                            <TextBlock Text="КАРТА" Foreground="#1976D2" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                    <mah:DropDownButton Content="ОТЧЕТЫ И ПЕЧАТЬ" 
                                        Margin="0,5,10,5"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="#2E7D32"
                                        FontWeight="SemiBold"
                                        FontSize="14"
                                        Cursor="Hand"
                                        ToolTip="Документы и сопроводительные формы">
                        <mah:DropDownButton.Icon>
                            <iconPacks:PackIconMaterial Kind="Printer" Margin="0,0,8,0" Foreground="#2E7D32"/>
                        </mah:DropDownButton.Icon>

                        <mah:DropDownButton.Items>
                            <MenuItem Header="Маршрутный лист покупателей (Excel)" Command="{Binding PrintRouteManifestCommand}">
                                <MenuItem.Icon>
                                    <iconPacks:PackIconMaterial Kind="FileExcelBox" Foreground="#2E7D32"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Товарно-транспортная накладная (ТТН)" Command="{Binding PrintDriverDocumentCommand}">
                                <MenuItem.Icon>
                                    <iconPacks:PackIconMaterial Kind="FilePdfBox" Foreground="#D32F2F"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Header="Сгенерировать этикетки для груза" Command="{Binding PrintLabelsCommand}">
                                <MenuItem.Icon>
                                    <iconPacks:PackIconMaterial Kind="BarcodeScan" Foreground="#424242"/>
                                </MenuItem.Icon>
                            </MenuItem>
                        </mah:DropDownButton.Items>
                    </mah:DropDownButton>
                </WrapPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Command="{Binding DeleteCommand}" 
                            Visibility="{Binding Converter={StaticResource PermissionToVisibility}, ConverterParameter=DeleteWaybills}"
                            Style="{StaticResource MenuButton}" 
                            Foreground="#D32F2F" Margin="0,5,10,5">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="CloseBoxOutline" Foreground="#D32F2F" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="УДАЛИТЬ" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Content="РЕДАКТИРОВАТЬ" 
                            Command="{Binding EditCommand}" 
                            Visibility="{Binding Converter={StaticResource PermissionToVisibility}, ConverterParameter=EditWaybills}"
                            Style="{StaticResource MenuButton}" Margin="0,5,10,5"/>
                    <Button Content="+ СОЗДАТЬ ПУТЕВОЙ ЛИСТ" 
                            Command="{Binding AddCommand}" 
                            Visibility="{Binding Converter={StaticResource PermissionToVisibility}, ConverterParameter=EditWaybills}"
                            Style="{StaticResource PrimaryButton}" Margin="0,5,0,5"/>
                </StackPanel>
            </Grid>
        </Border>
        <ProgressBar Grid.Row="1" IsIndeterminate="True" VerticalAlignment="Top" Height="4" BorderThickness="0"
                     Foreground="{StaticResource PrimaryBrush}" Background="Transparent"
                     Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
    </Grid>
</UserControl>